# ============================================================
# 千摊智脑 — 环境变量模板
# 复制为 .env 后填入真实值
# ============================================================
# 环境标识: development | staging | production
APP_ENV=development
DEBUG=true

# ── 数据库 ──
# 开发: SQLite（开箱即用）
# 生产: PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./qiantan_dev.db
DB_BACKEND=sqlite
# 生产时取消下面注释，并注释上面两行：
# DATABASE_URL=postgresql+asyncpg://qiantan:CHANGE_ME@localhost:5432/qiantan
# DB_BACKEND=postgresql

# ── JWT ──
# 本地: 任意值即可（但要求 ≥32 字节）
# 生产: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_MIN_32_BYTES
JWT_EXPIRE_MINUTES=10080
# 管理后台独立短会话（HttpOnly Cookie）
ADMIN_JWT_EXPIRE_MINUTES=30
ADMIN_COOKIE_NAME=admin_session

# ── 微信小程序 ──
# 开发环境缺省时自动 mock openid，无需配置
# 测试/生产必须填入真实值
WECHAT_APPID=
WECHAT_SECRET=

# ── 鉴权回退（仅 dev，生产必须 false）──
AUTH_ALLOW_FALLBACK=true

# ── CORS ──
# 开发: *
# 生产: https://servicewechat.com,https://your-admin.example.com
CORS_ORIGINS=*

# ── 端口 ──
# 后端 API 服务端口（统一 8000）
API_PORT=8000

# ── 文件上传 ──
UPLOAD_DIR=./uploads

# ── 外部 API ──
ASR_API_KEY=
WEATHER_API_KEY=
WEATHER_CITY_ID=101020100

# ── 生产安全（上线前逐一配置）──
# 以下在 APP_ENV=production 时启动自检拦截：
# - JWT_SECRET 不得为默认值
# - AUTH_ALLOW_FALLBACK 必须为 false
# - CORS_ORIGINS 建议不为 *

# ── 视觉识别模型（ONNX 推理 / P0-3）──
# 模型文件路径（例如 ./models/yolov8n.onnx）。为空则禁用模型推理。
VISION_MODEL_PATH=
# 推理设备：cpu 或 cuda
VISION_MODEL_DEVICE=cpu
# 置信度阈值（0.0-1.0），低于此值的检测结果将被丢弃
VISION_CONFIDENCE_THRESHOLD=0.5
# 严格模式：为 true 且 APP_ENV=production 时，模型不可用返回 HTTP 503
# 而非静默返回空结果。生产环境强烈建议设为 true。
VISION_STRICT_MODE=false

# ── Sentry 错误追踪 ──
# 不配置则静默跳过，不影响服务启动
SENTRY_DSN=
# 环境标识（留空时自动取 APP_ENV）
SENTRY_ENVIRONMENT=
# 性能追踪采样率（0.0-1.0），默认 0.1
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── 审计日志归档 ──
# 审计日志保留天数，超过后归档到压缩文件并清理数据库记录
AUDIT_ARCHIVE_DAYS=90
# 是否启用自动归档
AUDIT_ARCHIVE_ENABLED=true

# ── 数据库备份 ──
# 备份文件存储目录
BACKUP_DIR=./backups
# 日备份保留天数
BACKUP_RETENTION_DAILY=7
