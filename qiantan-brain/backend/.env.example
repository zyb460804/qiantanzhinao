# 千摊智脑后端环境变量。复制为 backend/.env（本地）或部署平台 Secret。
DEBUG=true
RUN_MIGRATIONS_ON_STARTUP=true
DATABASE_URL=sqlite+aiosqlite:///./qiantan_dev.db
DB_BACKEND=sqlite

# JWT / 微信登录。生产 JWT_SECRET 至少 32 字节。
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_EXPIRE_MINUTES=10080
WECHAT_APPID=
WECHAT_SECRET=
AUTH_ALLOW_FALLBACK=false
CORS_ORIGINS=*

ASR_API_KEY=
ASR_API_URL=https://iat-api.xfyun.cn/v2/iat
ASR_APP_ID=
ASR_API_SECRET=

WEATHER_API_KEY=
WEATHER_CITY_ID=101020100
UPLOAD_DIR=./uploads
AUDIO_DIR=./uploads/audio
