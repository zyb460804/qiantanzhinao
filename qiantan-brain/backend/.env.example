APP_ENV=development
# 千摊智脑后端环境变量。复制为 backend/.env（本地）或部署平台 Secret。
DEBUG=true
RUN_MIGRATIONS_ON_STARTUP=true
DATABASE_URL=sqlite+aiosqlite:///./qiantan_dev.db
DB_BACKEND=sqlite

# JWT / 微信登录。生产 JWT_SECRET 至少 32 字节。
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_EXPIRE_MINUTES=10080
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_API_BASE=https://api.mch.weixin.qq.com
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PATH=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
AUTH_ALLOW_FALLBACK=false
CORS_ORIGINS=*

ASR_API_KEY=
ASR_API_URL=https://iat-api.xfyun.cn/v2/iat
ASR_APP_ID=
ASR_API_SECRET=

WEATHER_API_KEY=
WEATHER_CITY_ID=101020100
UPLOAD_DIR=./uploads
AUDIO_DIR=./uploads/audio

# ------------------------------------------------------------------
# 视觉识别（ONNX 推理 / P0-3）
# ------------------------------------------------------------------
# 模型文件路径（例如 ./models/yolov8n.onnx）。为空则禁用模型推理。
VISION_MODEL_PATH=
# 推理设备：cpu 或 cuda
VISION_MODEL_DEVICE=cpu
# 置信度阈值（0.0-1.0），低于此值的检测结果将被丢弃
VISION_CONFIDENCE_THRESHOLD=0.5
# 严格模式：为 true 且 APP_ENV=production 时，模型不可用返回 HTTP 503
# 而非静默返回空结果。生产环境强烈建议设为 true。
VISION_STRICT_MODE=false

# ── Sentry 错误追踪 ──
# 不配置则静默跳过，不影响服务启动
SENTRY_DSN=
# 环境标识（留空时自动取 APP_ENV）
SENTRY_ENVIRONMENT=
# 性能追踪采样率（0.0-1.0），默认 0.1
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── 审计日志归档 ──
# 审计日志保留天数，超过后归档到压缩文件并清理数据库记录
AUDIT_ARCHIVE_DAYS=90
# 是否启用自动归档
AUDIT_ARCHIVE_ENABLED=true

# ── 数据库备份 ──
# 备份文件存储目录
BACKUP_DIR=./backups
# 日备份保留天数
BACKUP_RETENTION_DAILY=7
