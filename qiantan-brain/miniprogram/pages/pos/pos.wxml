<view class="page-shell pos-page skin-{{skin}}">
  <view class="page-hero pos-hero">
    <text class="eyebrow">SMART POS · 组合支付 · 挂单 · 退款</text>
    <view class="pos-top"><view><text class="pos-label">本单应收</text><text class="pos-amount">¥{{payableAmount}}</text></view><mascot size="md" mood="{{submitting ? 'think' : 'idle'}}" /></view>
    <text class="pos-sub">选商品 → 称重 → 收款 → 自动扣批次库存</text>
  </view>

  <view class="status-strip" wx:if="{{pendingCount}}"><text>有 {{pendingCount}} 笔离线订单待同步</text><text class="link" bindtap="retryFailed">重试</text></view>

  <view class="pos-flow">
    <view class="flow-cell active"><text class="flow-no">1</text><text class="flow-label">选商品</text><text class="flow-value">{{products.length}} 可售</text></view>
    <view class="flow-line"></view>
    <view class="flow-cell {{cart.length ? 'active' : ''}}"><text class="flow-no">2</text><text class="flow-label">核数量</text><text class="flow-value">{{cart.length}} 项</text></view>
    <view class="flow-line"></view>
    <view class="flow-cell {{cart.length ? 'active' : ''}}"><text class="flow-no">3</text><text class="flow-label">收款</text><text class="flow-value">¥{{payableAmount}}</text></view>
  </view>

  <!-- ====== 可售商品 ====== -->
  <view class="section-head"><text class="section-title">可售商品</text><text class="section-caption">库存与售价来自真实账本</text></view>
  <scroll-view scroll-x class="product-scroll" wx:if="{{products.length}}">
    <view class="product-row">
      <view class="product-card" wx:for="{{products}}" wx:key="product_id" data-index="{{index}}" bindtap="addProduct">
        <text class="product-name">{{item.sku_name || item.product_name}}</text>
        <text class="product-stock">余 {{item.current_qty}}{{item.unit}}</text>
        <text class="product-price">¥{{item.sale_price}}/{{item.unit}}</text>
        <text class="estimate" wx:if="{{item.price_is_estimated}}">参考售价</text>
      </view>
    </view>
  </scroll-view>
  <view class="empty-state" wx:else><text>{{loading ? '正在读取库存…' : '暂无可售库存，请先采购入库'}}</text></view>

  <!-- ====== 购物车 ====== -->
  <view class="section-head"><text class="section-title">本单商品</text><text class="section-caption">点数量可输入称重结果</text></view>
  <view class="cart" wx:if="{{cart.length}}">
    <view class="cart-item" wx:for="{{cart}}" wx:key="product_id">
      <view class="cart-main"><text class="cart-name">{{item.product_name}}</text><text class="cart-price">¥{{item.unit_price}}/{{item.unit}} · 小计 ¥{{item.line_total}}</text></view>
      <view class="qty"><button size="mini" data-index="{{index}}" data-delta="-1" bindtap="changeQty">−</button><text data-index="{{index}}" bindtap="editQty">{{item.quantity}}{{item.unit}}</text><button size="mini" data-index="{{index}}" data-delta="1" bindtap="changeQty">＋</button></view>
    </view>
    <view class="summary-line"><text>商品金额</text><text>¥{{grossAmount}}</text></view>
    <view class="summary-line discount" bindtap="editDiscount"><text>整单优惠（点此修改）</text><text>-¥{{discountAmount}}</text></view>
    <view class="summary-line total"><text>应收</text><text>¥{{payableAmount}}</text></view>
  </view>
  <view class="empty-state" wx:else><text>点击上方商品开始开单</text></view>

  <!-- ====== 收款方式 ====== -->
  <view class="section-head">
    <text class="section-title">收款方式</text>
    <text class="link" bindtap="toggleMultiPay">{{multiPay ? '切换单一支付' : '切换组合支付'}}</text>
  </view>

  <!-- 单一支付 -->
  <view class="payment-grid" wx:if="{{!multiPay}}">
    <view wx:for="{{paymentMethods}}" wx:key="key" class="payment-chip {{paymentMethod === item.key ? 'active' : ''}}" data-method="{{item.key}}" bindtap="selectPayment">{{item.label}}</view>
  </view>

  <!-- 组合支付 -->
  <view class="multi-pay" wx:if="{{multiPay}}">
    <view class="split-row" wx:for="{{paymentMethods}}" wx:key="key">
      <text class="split-label">{{item.label}}</text>
      <text class="split-amount" data-method="{{item.key}}" bindtap="editPayAmount">¥{{paySplit[item.key] || 0}}</text>
    </view>
    <text class="split-hint">点击金额修改各渠道分摊</text>
  </view>

  <!-- 操作按钮行 -->
  <view class="action-row">
    <button class="hold-btn" disabled="{{!cart.length || submitting}}" loading="{{submitting}}" bindtap="holdOrder">挂单</button>
    <button class="checkout" disabled="{{!cart.length || submitting}}" loading="{{submitting}}" bindtap="checkout">{{paymentMethod === 'credit' && !multiPay ? '确认赊账' : '确认收款'}} ¥{{payableAmount}}</button>
  </view>

  <!-- ====== 挂单列表 ====== -->
  <view class="section-head held-head" bindtap="toggleHeldOrders">
    <text class="section-title">挂单列表 {{heldOrders.length ? '(' + heldOrders.length + ')' : ''}}</text>
    <text class="section-caption">{{showHeld ? '点击收起' : '点击展开'}}</text>
  </view>
  <view class="held-list" wx:if="{{showHeld}}">
    <view class="held-empty" wx:if="{{!heldOrders.length}}"><text>暂无挂单</text></view>
    <view class="held-item" wx:for="{{heldOrders}}" wx:key="order_id" data-id="{{item.order_id}}" bindtap="resumeHeld">
      <view class="held-main"><text class="held-no">{{item.order_no}}</text><text class="held-time">{{item.held_at}}</text></view>
      <view class="held-right"><text class="held-amount">¥{{item.total_amount}}</text><text class="held-items">{{item.item_count}}项</text></view>
    </view>
  </view>

  <!-- ====== 日结 ====== -->
  <view class="settlement-card" wx:if="{{settlement}}">
    <text class="settlement-title">今日日结 · {{settlement.status}}</text>
    <view class="settlement-grid">
      <text>销售 ¥{{settlement.total_sales}}</text><text>微信 ¥{{settlement.wechat_amount}}</text>
      <text>现金 ¥{{settlement.cash_amount}}</text><text>赊账 ¥{{settlement.credit_amount}}</text>
      <text wx:if="{{settlement.refund_amount}}">退款 ¥{{settlement.refund_amount}}</text>
      <text wx:if="{{settlement.waste_cost}}">报损 ¥{{settlement.waste_cost}}</text>
      <text wx:if="{{settlement.purchase_paid}}">采购付款 ¥{{settlement.purchase_paid}}</text>
      <text wx:if="{{settlement.customer_repay}}">客户回款 ¥{{settlement.customer_repay}}</text>
    </view>
    <text class="diff {{settlement.isBalanced ? 'ok' : 'warn'}}">差异 ¥{{settlement.diff_amount}}</text>
    <text class="settlement-extra" wx:if="{{settlement.estimated_gross_profit}}">预计毛利 ¥{{settlement.estimated_gross_profit}} · 现金净流入 ¥{{settlement.net_cash_flow}}</text>
  </view>
  <button class="close-day" bindtap="closeDay" loading="{{submitting}}">确认今日日结</button>

  <!-- ====== 最近订单 ====== -->
  <view class="section-head"><text class="section-title">最近订单</text><text class="section-caption">点击可退款</text></view>
  <view class="record-list">
    <view class="pos-record" wx:for="{{records}}" wx:key="order_id" data-id="{{item.order_id}}" bindtap="openRefund">
      <view class="rec-body"><text class="rec-title">{{item.order_no}}</text><text class="rec-time">{{item.created_at}}</text></view>
      <view><text class="rec-amount">¥{{item.total_amount}}</text><text class="rec-status {{item.status === 'refunded' ? 'refunded' : ''}}">{{item.status === 'paid' ? '已付' : item.status === 'credit' ? '赊账' : item.status === 'partial' ? '部分' : item.status === 'refunded' ? '已退' : item.status === 'partial_refund' ? '部分退' : item.status === 'held' ? '挂单' : item.status}}</text></view>
    </view>
  </view>

  <!-- ====== 退款弹窗 ====== -->
  <view class="refund-mask" wx:if="{{showRefund}}" catchtap="closeRefund">
    <view class="refund-modal" catchtap="stopMaskTap">
      <text class="refund-title">退款 · {{refundOrder.order_no}}</text>
      <text class="refund-amount">金额 ¥{{refundOrder.total_amount}}</text>
      <view class="refund-field">
        <text class="refund-label">退款原因</text>
        <input class="refund-input" placeholder="例如：顾客退货、商品质量问题" value="{{refundReason}}" bindinput="inputRefundReason" />
      </view>
      <view class="refund-toggle" bindtap="toggleRefundPartial">
        <text>部分退款（按商品退）</text>
        <view class="toggle {{refundPartial ? 'on' : 'off'}}"><view class="toggle-knob"></view></view>
      </view>
      <view wx:if="{{refundPartial && refundItems.length > 0}}" class="refund-item-list">
        <view wx:for="{{refundItems}}" wx:key="item_id" class="refund-item-row">
          <text class="refund-item-name">{{item.product_name}}</text>
          <text class="refund-item-qty">购买 {{item.quantity}}{{item.unit}}</text>
          <input class="refund-item-input" type="digit" value="{{item.refund_qty}}" data-idx="{{index}}" bindinput="editRefundQty" placeholder="0" />
        </view>
      </view>
      <view class="refund-toggle" bindtap="toggleReturnStock">
        <text>退回可售库存</text>
        <view class="toggle {{refundReturnStock ? 'on' : 'off'}}"><view class="toggle-knob"></view></view>
      </view>
      <view class="refund-actions">
        <button class="refund-cancel" bindtap="closeRefund">取消</button>
        <button class="refund-confirm" disabled="{{!refundReason || refundSubmitting}}" loading="{{refundSubmitting}}" bindtap="confirmRefund">{{refundSubmitting ? '退款中…' : (refundPartial ? '确认部分退款' : '确认退款')}}</button>
      </view>
    </view>
  </view>
</view>
