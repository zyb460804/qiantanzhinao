/* 经营报告 · v2.2 视觉（生鲜元气） */
.report-page { padding-top: 22rpx; }
.report-hero { padding-bottom: 32rpx; }
/* Hero 的装饰圆位于右下角，必须禁止它遮挡“近30日”的点击区域。 */
.report-hero::after { pointer-events: none; z-index: 0; }
.report-hero > view, .report-hero > text { position: relative; z-index: 1; }
.hero-kick { font-size: 22rpx; letter-spacing: 2rpx; color: var(--green-200); font-weight: 700; }
.hero-title { font-family: var(--font-display); font-size: 64rpx; font-weight: 900; color: #fff; letter-spacing: -1rpx; display: block; line-height: 1.05; }
.hero-desc { display: block; font-size: 24rpx; color: rgba(255,255,255,.72); margin-top: 8rpx; }

.range-tabs { display: flex; gap: 12rpx; margin-top: 28rpx; background: rgba(255,255,255,.14); padding: 8rpx; border-radius: 99rpx; position: relative; z-index: 2; }
.range-tab { flex: 1; text-align: center; font-size: 24rpx; color: rgba(255,255,255,.78); padding: 14rpx; border-radius: 99rpx; transition: background var(--dur-fast), color var(--dur-fast), transform var(--dur-fast); line-height: 1.4; position: relative; z-index: 3; }
.range-tab.active { background: #fff; color: var(--green-800); font-weight: 700; }

/* 核心指标卡 */
.kpi-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.kpi { background: var(--paper); border: 1px solid var(--line); border-radius: 24rpx; padding: 24rpx; display: flex; flex-direction: column; gap: 10rpx; }
.kpi-top { display: flex; align-items: center; gap: 12rpx; }
.kpi-label { font-size: 24rpx; color: var(--muted); }
.kpi-value { font-family: var(--font-num); font-size: 52rpx; font-weight: 800; color: var(--ink); line-height: 1; letter-spacing: -1rpx; }
.kpi-green .kpi-value { color: var(--green-700); }
.kpi-amber .kpi-value { color: var(--corn-deep, #9a6b00); }
.kpi-blue .kpi-value { color: var(--blue); }
.kpi-red .kpi-value { color: var(--red); }
.kpi-change { display: flex; align-items: center; gap: 6rpx; font-size: 22rpx; font-family: var(--font-num); }
.kpi-change.up { color: var(--green-700); }
.kpi-change.down { color: var(--red); }
.kpi-sub { font-size: 22rpx; color: var(--muted); }

.block { margin-top: 40rpx; }

/* 趋势图表 */
.chart-card { padding: 24rpx; }
.chart-legend { display: flex; gap: 24rpx; margin-bottom: 12rpx; font-size: 22rpx; color: var(--muted); }
.legend-item { position: relative; padding-left: 24rpx; }
.legend-item::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 16rpx; height: 16rpx; border-radius: 50%; }
.legend-revenue::before { background: var(--green-600); }
.legend-profit::before { background: var(--corn); }
.legend-aov::before { background: var(--blue, #2E7DD1); }
.trend-canvas { width: 100%; height: 360rpx; }

/* 销量排行榜 */
.rank-card { padding: 8rpx 24rpx; }
.rank-row { display: flex; align-items: center; gap: 16rpx; padding: 20rpx 0; border-bottom: 1rpx solid var(--line); }
.rank-row:last-child { border-bottom: none; }
.rank-num { width: 48rpx; height: 48rpx; border-radius: 14rpx; background: var(--paper-2); color: var(--muted); font-weight: 800; font-family: var(--font-num); display: flex; align-items: center; justify-content: center; flex: none; }
.rank-num.rank-1 { background: var(--green-700); color: #fff; }
.rank-num.rank-2 { background: var(--corn); color: #3a2a00; }
.rank-num.rank-3 { background: var(--red-soft); color: var(--red); }
.rank-info { flex: 1; display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.rank-name { font-size: 28rpx; font-weight: 700; color: var(--ink); }
.rank-meta { display: flex; justify-content: space-between; font-size: 22rpx; color: var(--muted); }
.rank-revenue { font-family: var(--font-num); color: var(--green-700); }
.rank-bar-track { height: 10rpx; border-radius: 99rpx; background: var(--paper-2); overflow: hidden; }
.rank-bar-fill { height: 100%; border-radius: 99rpx; background: var(--green-500); }
.rank-bar-fill.rank-bar-1 { background: var(--green-600); }
.rank-bar-fill.rank-bar-2 { background: var(--corn); }
.rank-bar-fill.rank-bar-3 { background: var(--red); }

/* 损耗 / 滞销 */
.waste-card { padding: 8rpx 24rpx; }
.waste-row { display: flex; align-items: center; gap: 16rpx; padding: 20rpx 0; border-bottom: 1rpx solid var(--line); }
.waste-row:last-child { border-bottom: none; }
.waste-mark { width: 48rpx; height: 48rpx; border-radius: 14rpx; background: var(--corn-soft); color: var(--corn-deep, #9a6b00); font-weight: 800; display: flex; align-items: center; justify-content: center; flex: none; }
.waste-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; min-width: 0; }
.waste-name { font-size: 28rpx; font-weight: 700; color: var(--ink); }
.waste-detail { font-size: 22rpx; color: var(--muted); }

/* AI 总结 */
.ai-card { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.ai-head { display: flex; align-items: center; gap: 16rpx; }
.ai-head-copy { display: flex; flex-direction: column; }
.ai-name { font-size: 28rpx; font-weight: 800; color: var(--ink); }
.ai-role { font-size: 20rpx; color: var(--green-700); }

.health-section { display: flex; align-items: center; gap: 24rpx; background: var(--green-100); border-radius: 20rpx; padding: 24rpx; }
.health-ring { width: 120rpx; height: 120rpx; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; flex: none; }
.health-score { font-family: var(--font-num); font-size: 48rpx; font-weight: 800; color: var(--green-800); line-height: 1; }
.health-unit { font-size: 20rpx; color: var(--green-800); }
.health-title { font-size: 28rpx; font-weight: 800; color: var(--ink); display: block; }
.health-tip { font-size: 22rpx; color: var(--muted); }

.ai-summary { font-size: 26rpx; line-height: 1.7; color: var(--ink-2); }
.action-title { font-size: 24rpx; font-weight: 700; color: var(--ink); margin-bottom: 12rpx; }
.action-list { display: flex; flex-direction: column; gap: 12rpx; }
.action-item { display: flex; align-items: flex-start; gap: 12rpx; }
.action-bullet { width: 36rpx; height: 36rpx; border-radius: 50%; background: var(--green-700); color: #fff; font-size: 22rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; flex: none; }
.action-text { font-size: 26rpx; color: var(--ink-2); line-height: 1.5; }

.adoption-row { display: flex; justify-content: space-between; font-size: 24rpx; }
.adoption-label { color: var(--muted); }
.adoption-value { font-family: var(--font-num); font-weight: 700; color: var(--ink); }
.adoption-bar-track { height: 14rpx; border-radius: 99rpx; background: var(--paper-2); overflow: hidden; margin: 12rpx 0; }
.adoption-bar-fill { height: 100%; background: var(--green-600); border-radius: 99rpx; transition: width .6s var(--ease-expo); }
.adoption-rate { font-size: 22rpx; color: var(--green-700); font-weight: 700; }

/* 语音入口卡片 */
.voice-entry-card { display: flex; align-items: center; justify-content: space-between; padding: 28rpx; }
.voice-entry-title { font-size: 30rpx; font-weight: 800; color: var(--ink); display: block; }
.voice-entry-desc { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; display: block; }
.voice-btn { flex: none; }

/* 骨架屏 */
.kpi-skel { gap: 16rpx; }
.skeleton-block.line { height: 24rpx; border-radius: 8rpx; background: var(--paper-2); position: relative; overflow: hidden; }
.skeleton-block.line::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, var(--paper), transparent); animation: shimmer 1.4s infinite; }
.w40 { width: 40%; } .w50 { width: 50%; } .w60 { width: 60%; } .w70 { width: 70%; } .w80 { width: 80%; } .w100 { width: 100%; }

.loading-state { display: flex; align-items: center; gap: 16rpx; justify-content: center; padding: 48rpx; color: var(--muted); font-size: 24rpx; }
.loading-spinner { width: 36rpx; height: 36rpx; border-radius: 50%; border: 4rpx solid var(--green-200); border-top-color: var(--green-700); animation: spin 1s linear infinite; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 64rpx 32rpx; text-align: center; }
.empty-tip { font-size: 24rpx; color: var(--muted); }

/* 2026 统一设计升级：报告阅读体验 */
.report-page { padding-bottom: 90rpx; }
.report-hero { margin-bottom: 0; }
.report-signal-strip { display: flex; align-items: center; margin: 18rpx 0 24rpx; padding: 20rpx 12rpx; background: var(--paper); border: 1.5rpx solid var(--ring); border-radius: 22rpx; box-shadow: var(--shadow-sm); }
.report-signal-strip > view { flex: 1; text-align: center; }
.signal-num { display: block; color: var(--ink); font-family: var(--font-num); font-size: 31rpx; font-weight: 850; }
.signal-num.warn { color: var(--corn-deep, #9a6b00); }.signal-num.good { color: var(--green-700); }
.signal-label { display: block; margin-top: 5rpx; color: var(--muted); font-size: 19rpx; }
.signal-divider { width: 1rpx; height: 42rpx; flex: 0 0 auto !important; background: var(--line); }
.kpi { border: 1.5rpx solid var(--ring); box-shadow: var(--shadow-sm); }
.kpi-value { letter-spacing: -.5rpx; }
.report-page .card { border: 1.5rpx solid var(--ring); box-shadow: var(--shadow-sm); }
.chart-card { overflow: hidden; }
.rank-row, .waste-row { padding-top: 22rpx; padding-bottom: 22rpx; }
.ai-card { position: relative; overflow: hidden; }
.ai-card::before { position: absolute; top: 0; left: 0; right: 0; height: 6rpx; background: linear-gradient(90deg, var(--green-700), var(--corn)); content: ''; }
