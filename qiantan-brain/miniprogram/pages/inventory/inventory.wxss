/* 库存总览 · v2.2 视觉（生鲜元气） */
.inv-page { padding-top: 22rpx; }

/* ── Hero ──────────────────────────────── */
.inv-hero { padding-bottom: 36rpx; }
.hero-top { display: flex; align-items: center; justify-content: space-between; }
.hero-kick { font-size: 22rpx; letter-spacing: 2rpx; color: var(--green-700); font-weight: 700; }
.refresh-btn { display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; color: #fff; opacity: .82; padding: 8rpx 16rpx; border-radius: 99rpx; background: rgba(255,255,255,.14); }
.refresh-btn.is-loading icon { animation: spin 1s linear infinite; }
.hero-figures { display: flex; align-items: flex-end; gap: 44rpx; margin-top: 26rpx; }
.hero-figure { display: flex; flex-direction: column; }
.hero-figure.sub { opacity: .82; }
.hf-num { font-family: var(--font-num); font-size: 92rpx; font-weight: 800; line-height: 1; color: #fff; letter-spacing: -2rpx; }
.hf-num.sm { font-size: 56rpx; color: var(--corn); }
.hf-unit { font-size: 24rpx; color: rgba(255,255,255,.72); margin-top: 10rpx; }
.hero-strip { display: flex; align-items: center; gap: 8rpx; margin-top: 34rpx; padding-top: 26rpx; border-top: 1rpx solid rgba(255,255,255,.16); }
.strip-item { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.si-num { font-family: var(--font-num); font-size: 42rpx; font-weight: 800; color: #fff; line-height: 1; }
.si-pct { font-size: 24rpx; }
.si-lab { font-size: 20rpx; color: rgba(255,255,255,.66); }
.strip-sep { width: 1rpx; height: 50rpx; background: rgba(255,255,255,.16); }

/* ── 骨架屏 ───────────────────────────── */
.skel-wrap { padding: 32rpx; display: flex; flex-direction: column; gap: 20rpx; }
.skel-wrap .skeleton-block { background: var(--paper-2); border-radius: 16rpx; position: relative; overflow: hidden; }
.skel-wrap .skeleton-block::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, var(--paper), transparent); animation: shimmer 1.4s infinite; }
.skel-wrap .card-line { height: 120rpx; border-radius: 24rpx; }
.skel-wrap .card-line.short { width: 66%; }
.skel-wrap .row { display: flex; gap: 16rpx; }
.skel-wrap .sq { width: 120rpx; height: 120rpx; border-radius: 24rpx; flex: none; }
.skel-wrap .grow { flex: 1; height: 120rpx; border-radius: 24rpx; }

/* ── 区块 ─────────────────────────────── */
.block { margin-top: 40rpx; }

/* 小智洞察：覆盖基类 .insight-card 内部布局 */
.insight-card { display: flex; align-items: center; gap: 20rpx; }
.insight-card mascot { flex: none; }
.insight-action { flex: none; margin-left: auto; background: #fff; color: var(--green-800); font-size: 24rpx; font-weight: 700; padding: 12rpx 24rpx; border-radius: 99rpx; }

/* ── 临期提醒 ─────────────────────────── */
.expiry-list { display: flex; flex-direction: column; gap: 16rpx; }
.expiry-card { display: flex; gap: 16rpx; background: var(--paper); border: 1rpx solid var(--line); border-radius: 24rpx; padding: 24rpx; }
.expiry-card.danger { border-color: var(--red-soft); background: var(--red-soft); }
.expiry-card.warn { border-color: var(--corn-soft); background: var(--corn-soft); }
.expiry-badge { align-self: flex-start; font-size: 20rpx; font-weight: 700; padding: 6rpx 14rpx; border-radius: 99rpx; }
.expiry-badge.danger { background: var(--red); color: #fff; }
.expiry-badge.warn { background: var(--corn); color: #3a2a00; }
.expiry-copy { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.expiry-title-line { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.expiry-name { font-size: 28rpx; font-weight: 700; color: var(--ink); }
.expiry-qty { font-size: 22rpx; color: var(--corn-deep, #9a6b00); font-family: var(--font-num); }
.expiry-message { font-size: 24rpx; color: var(--ink-2); }
.expiry-meta { display: flex; gap: 16rpx; font-size: 20rpx; color: var(--muted); }
.meta-disc { color: var(--corn-deep, #9a6b00); font-weight: 700; }

/* ── 健康概览 ─────────────────────────── */
.health-grid { display: flex; gap: 16rpx; }
.health-item { flex: 1; background: var(--paper); border: 1rpx solid var(--line); border-radius: 24rpx; padding: 26rpx 16rpx; display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.health-item.good { border-color: var(--green-200); }
.health-item.warn { border-color: var(--corn-soft); }
.health-item.empty { border-color: var(--red-soft); }
.health-icon { width: 64rpx; height: 64rpx; border-radius: 18rpx; background: var(--paper-2); display: flex; align-items: center; justify-content: center; }
.health-num { font-family: var(--font-num); font-size: 52rpx; font-weight: 800; color: var(--ink); line-height: 1; }
.health-label { font-size: 22rpx; color: var(--muted); }

/* ── 库存结构图 ───────────────────────── */
.chart-card { padding: 26rpx 24rpx 18rpx; }
.chart-summary { display: flex; align-items: flex-end; justify-content: space-between; gap: 18rpx; padding: 0 4rpx 16rpx; border-bottom: 1rpx solid var(--line); }
.chart-kicker { display: block; font-size: 20rpx; color: var(--muted); }
.chart-main { font-size: 30rpx; font-weight: 700; color: var(--ink); }
.chart-legend { display: flex; align-items: center; gap: 8rpx; font-size: 20rpx; color: var(--muted); }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 50%; margin-left: 8rpx; }
.legend-dot.green { background: var(--green-600); }
.legend-dot.amber { background: var(--corn); }

/* ── 工具条 ───────────────────────────── */
.inv-tools { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 24rpx; }
.search-box { display: flex; align-items: center; gap: 12rpx; background: var(--paper); border: 1rpx solid var(--line); border-radius: 99rpx; padding: 16rpx 24rpx; }
.search-box input { flex: 1; font-size: 26rpx; color: var(--ink); }
.search-clear { font-size: 38rpx; color: var(--muted); padding: 0 8rpx; line-height: 1; }
.filter-scroll { width: 100%; white-space: nowrap; }
.filter-list { display: inline-flex; gap: 12rpx; padding: 4rpx 0; }
.chip.active.warn { background: var(--corn-soft); color: var(--corn-deep, #9a6b00); border-color: var(--corn-soft); }
.chip.active.danger { background: var(--red-soft); color: var(--red); border-color: var(--red-soft); }
.sort-tabs { display: flex; gap: 12rpx; padding: 8rpx; background: var(--paper-2); border-radius: 20rpx; }
.sort-tab { flex: 1; text-align: center; font-size: 24rpx; color: var(--muted); padding: 14rpx; border-radius: 16rpx; }
.sort-tab.active { color: var(--green-800); background: var(--paper); font-weight: 700; box-shadow: var(--shadow-sm); }

/* ── 空状态 ───────────────────────────── */
.empty-state { display: flex; flex-direction: column; align-items: center; gap: 16rpx; padding: 64rpx 32rpx; text-align: center; }
.empty-state.card { background: var(--paper); }
.empty-title { font-size: 30rpx; font-weight: 700; color: var(--ink); }
.empty-desc { font-size: 24rpx; color: var(--muted); }
.reset-filter { font-size: 24rpx; color: var(--green-700); font-weight: 700; }

/* ── 库存列表 ─────────────────────────── */
.inv-list { display: flex; flex-direction: column; gap: 16rpx; }
.inv-card { display: flex; gap: 20rpx; background: var(--paper); border: 1rpx solid var(--line); border-radius: 24rpx; padding: 24rpx; }
.inv-card.low { border-color: var(--corn-soft); }
.inv-card.empty { border-color: var(--red-soft); background: var(--red-soft); }
.product-avatar { width: 80rpx; height: 80rpx; border-radius: 20rpx; background: var(--green-100); color: var(--green-800); font-size: 36rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; flex: none; }
.inv-card.low .product-avatar { background: var(--corn-soft); color: var(--corn-deep, #9a6b00); }
.inv-card.empty .product-avatar { background: var(--red-soft); color: var(--red); }
.product-content { flex: 1; display: flex; flex-direction: column; gap: 12rpx; min-width: 0; }
.product-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12rpx; }
.product-title-wrap { display: flex; flex-direction: column; gap: 4rpx; flex: 1; min-width: 0; }
.product-title-line { display: flex; align-items: center; gap: 12rpx; }
.product-name { font-size: 30rpx; font-weight: 700; color: var(--ink); }
.status-pill { font-size: 20rpx; font-weight: 700; padding: 4rpx 12rpx; border-radius: 99rpx; flex: none; }
.status-pill.healthy { background: var(--green-100); color: var(--green-800); }
.status-pill.low { background: var(--corn-soft); color: var(--corn-deep, #9a6b00); }
.status-pill.empty { background: var(--red-soft); color: var(--red); }
.product-meta { font-size: 22rpx; color: var(--muted); }
.qty-block { display: flex; align-items: baseline; gap: 4rpx; flex: none; }
.qty-num { font-family: var(--font-num); font-size: 48rpx; font-weight: 800; line-height: 1; }
.qty-num.green { color: var(--green-700); }
.qty-num.amber { color: var(--corn-deep, #9a6b00); }
.qty-unit { font-size: 22rpx; color: var(--muted); }
.stock-track { height: 12rpx; border-radius: 99rpx; background: var(--paper-2); overflow: hidden; }
.stock-fill { height: 100%; border-radius: 99rpx; background: var(--green-500); transition: width .6s var(--ease-expo); }
.stock-fill.low { background: var(--corn); }
.stock-fill.empty { background: var(--red); }
.stock-caption { display: flex; justify-content: space-between; font-size: 20rpx; color: var(--muted); }

.reduce-motion .stock-fill { transition: none; }

/* v2.3：库存只在同一商品自身单位内解释，不展示混合单位总量和排行榜 */
.stock-caption-simple { justify-content:flex-start; margin-top:14rpx; padding-top:12rpx; border-top:1rpx solid var(--line); line-height:1.45; }

/* 商品卡快捷动作 + 智能引导（v3.1） */
.card-action-row { display:flex; gap:14rpx; margin-top:14rpx; }
.card-action-btn { font-size:22rpx; padding:8rpx 20rpx; border-radius:99rpx; color:var(--green-800); background:var(--green-50, rgba(23,92,69,.08)); }
.card-action-btn.warn { color:var(--corn-deep, #9a6b00); background:rgba(243,168,59,.14); }

.quick-action-row { display:flex; flex-direction:column; gap:16rpx; }
.quick-action-card { display:flex; align-items:center; gap:20rpx; padding:24rpx 28rpx; background:var(--surface); border:1rpx solid var(--line); border-radius:var(--r-lg, 20rpx); }
.quick-action-card:active { opacity:.82; }
.qa-glyph { width:72rpx; height:72rpx; border-radius:18rpx; display:flex; align-items:center; justify-content:center; font-size:30rpx; font-weight:700; color:#fff; background:var(--green-600); }
.qa-glyph.warn { background:var(--corn); }
.qa-glyph.danger { background:var(--red); }
.qa-copy { display:flex; flex-direction:column; gap:4rpx; }
.qa-title { font-size:28rpx; font-weight:600; color:var(--text, #1f2a24); }
.qa-desc { font-size:22rpx; color:var(--green-700); }
