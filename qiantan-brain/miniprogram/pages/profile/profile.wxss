/* ============================================================
 * 「我的」页面 v3.0 样式
 * 七模块: 经营快照 / 快捷操作 / 设备同步 / 工具 / 设置 / 帮助 / 关于
 * ============================================================ */

.profile-page { padding-top: 22rpx; padding-bottom: 160rpx; }

/* ── ① 经营快照 ── */
.snapshot-hero { padding-bottom: 34rpx; }
.snapshot-main { position: relative; z-index: 2; margin-top: 16rpx; }
.snapshot-revenue { display: block; font-family: var(--font-num); font-size: 62rpx; font-weight: 800; color: #fff; letter-spacing: -2rpx; }
.snapshot-label { display: block; margin-top: 6rpx; font-size: 24rpx; color: rgba(255,255,255,.72); }
.snapshot-label.muted { color: rgba(255,255,255,.55); }
.snapshot-stats { position: relative; z-index: 2; display: flex; gap: 18rpx; margin-top: 30rpx; padding-top: 24rpx; border-top: 1rpx solid rgba(255,255,255,.13); }
.sstat { flex: 1; text-align: center; }
.sstat-num { display: block; font-family: var(--font-num); font-size: 34rpx; font-weight: 750; color: #fff; }
.sstat-num.up { color: #7ee8a0; }
.sstat-num.down { color: #ffb088; }
.sstat-label { display: block; margin-top: 4rpx; font-size: 21rpx; color: rgba(255,255,255,.6); }
.snapshot-week { position: relative; z-index: 2; display: block; margin-top: 22rpx; padding: 14rpx 22rpx; background: rgba(255,255,255,.1); border-radius: 999rpx; font-size: 23rpx; color: rgba(255,255,255,.8); }

/* 骨架屏 */
.sk-bar { padding: 20rpx 0; }
.sk-bar .sk-line { height: 28rpx; margin: 12rpx 0; }

/* ── ② 快捷操作 ── */
.quick-grid { display: flex; gap: 16rpx; }
.quick-card { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 28rpx 12rpx; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); transition: transform var(--dur-fast) var(--ease-spring); }
.quick-card:active { transform: scale(.97); }
.quick-card .quick-title { display: block; margin-top: 8rpx; color: var(--ink); font-size: 26rpx; font-weight: 700; }
.quick-card .quick-desc { display: block; color: var(--muted); font-size: 21rpx; }

.quick-purchase { display: flex; align-items: center; justify-content: space-between; margin-top: 16rpx; padding: 24rpx 28rpx; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.quick-purchase:active { transform: scale(.99); }
.qp-left { display: flex; align-items: center; gap: 16rpx; }
.qp-title { color: var(--ink); font-size: 27rpx; font-weight: 700; }
.qp-right { display: flex; align-items: center; gap: 8rpx; }
.qp-badge { padding: 6rpx 16rpx; color: #fff; background: var(--red); border-radius: 999rpx; font-size: 21rpx; font-weight: 700; }
.qp-badge.muted { color: var(--muted); background: var(--line); }

/* ── ③ 设备与同步 ── */
.device-panel { overflow: hidden; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.device-row { display: flex; align-items: center; gap: 16rpx; min-height: 92rpx; padding: 18rpx 24rpx; border-bottom: 1rpx solid var(--line); }
.device-row:last-child { border-bottom: 0; }
.device-row.muted { justify-content: center; color: var(--muted); font-size: 24rpx; }
.dev-status { width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0; }
.dev-status.online { background: #2BA24C; box-shadow: 0 0 8rpx rgba(43,162,76,.4); }
.dev-status.unstable { background: #F3A83B; }
.dev-status.offline { background: #E5484D; }
.dev-name { flex: 1; color: var(--ink); font-size: 25rpx; font-weight: 600; }
.dev-time { color: var(--muted); font-size: 22rpx; }
.dev-action { color: var(--green-800); font-size: 22rpx; font-weight: 700; }
.sync-row { cursor: pointer; }

/* ── ④ 经营工具 ── */
.tool-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.tool-group { margin-top: 20rpx; }
.tool-group-head { display: flex; align-items: baseline; gap: 14rpx; margin-bottom: 14rpx; padding: 0 6rpx; }
.tool-group-title { font-size: 26rpx; font-weight: 700; color: var(--ink-1, #1f2a24); }
.tool-group-caption { font-size: 20rpx; color: var(--muted); }
.tool-chip { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 26rpx 12rpx; background: var(--paper); border: 1rpx solid var(--line); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.tool-chip:active { transform: translateY(1rpx); box-shadow: none; }
.tool-glyph { display: flex; align-items: center; justify-content: center; width: 76rpx; height: 76rpx; border-radius: 22rpx; font-size: 28rpx; font-weight: 800; }
.tool-glyph.blue { color: #2e6685; background: #e0eff7; }
.tool-glyph.corn { color: #8a4a06; background: #fdf0d8; }
.tool-glyph.green { color: var(--green-800); background: var(--green-100); }
.tool-name { color: var(--ink-2); font-size: 22rpx; font-weight: 650; }

/* ── ⑤ 摊位设置 ── */
.setting-group { overflow: hidden; margin-bottom: 18rpx; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.setting-row { display: flex; align-items: center; gap: 20rpx; min-height: 96rpx; padding: 20rpx 24rpx; border-bottom: 1rpx solid var(--line); }
.setting-row:last-child { border-bottom: 0; }
.setting-label { flex-shrink: 0; width: 140rpx; color: var(--muted); font-size: 24rpx; }
.setting-input { flex: 1; color: var(--ink); font-size: 28rpx; font-weight: 600; }
.setting-val { color: var(--ink); font-size: 28rpx; font-weight: 600; }
.setting-group-title { display: block; padding: 20rpx 24rpx 8rpx; color: var(--muted); font-size: 22rpx; }
.risk-opt { display: flex; align-items: center; gap: 14rpx; min-height: 88rpx; padding: 18rpx 24rpx; border-bottom: 1rpx solid var(--line); font-size: 25rpx; color: var(--ink-2); }
.risk-opt:last-child { border-bottom: 0; }
.risk-opt radio { transform: scale(.82); }

.save-btn { margin-top: 24rpx; min-height: 96rpx; color: #fff; background: var(--green-800); border-radius: 22rpx; font-size: 29rpx; font-weight: 750; box-shadow: 0 12rpx 26rpx rgba(23,92,69,.22); }
.save-btn:active { transform: scale(.99); }

/* ── ⑥ 帮助与反馈 ── */
.help-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.help-card { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 30rpx 16rpx; background: var(--paper); border: 1rpx solid var(--line); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.help-card:active { transform: scale(.98); }
.help-title { display: block; margin-top: 6rpx; color: var(--ink); font-size: 25rpx; font-weight: 700; }
.help-desc { display: block; color: var(--muted); font-size: 21rpx; }

/* ── ⑦ 关于 ── */
.about-section { overflow: hidden; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.about-row { display: flex; align-items: center; justify-content: space-between; min-height: 92rpx; padding: 20rpx 24rpx; border-bottom: 1rpx solid var(--line); font-size: 26rpx; color: var(--ink); }
.about-row:last-child { border-bottom: 0; }
.about-row .muted { color: var(--muted); font-size: 23rpx; }
