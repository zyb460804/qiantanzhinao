.fin-page { padding-bottom:100rpx; }
.tab-row { display:flex; gap:12rpx; margin:16rpx 0; overflow-x:auto; }
.tab-chip { padding:14rpx 24rpx; color:var(--muted); background:var(--paper); border:2rpx solid var(--line); border-radius:99rpx; font-size:24rpx; font-weight:700; white-space:nowrap; flex:0 0 auto; }
.tab-chip.active { color:#fff; background:var(--green-700); border-color:var(--green-700); }
.cat-list { overflow:hidden; background:var(--paper); border-radius:24rpx; box-shadow:var(--shadow); margin-bottom:20rpx; }
.cat-item { display:flex; align-items:center; padding:20rpx 24rpx; border-bottom:1rpx solid var(--line); gap:12rpx; }
.cat-item:last-child { border-bottom:none; }
.cat-main { flex:1; min-width:0; }
.cat-name { display:block; color:var(--ink); font-size:27rpx; font-weight:750; }
.cat-meta { display:block; margin-top:4rpx; color:var(--muted); font-size:20rpx; }
.cat-amount { color:var(--ink); font-family:var(--font-num); font-size:25rpx; font-weight:800; flex:0 0 auto; }
.act-btn.del { padding:6rpx 14rpx; color:#c0493d; background:rgba(201,67,51,.08); border-radius:99rpx; font-size:20rpx; }
.report-card { padding:24rpx; background:var(--paper); border-radius:24rpx; box-shadow:var(--shadow); }
.report-row { display:flex; justify-content:space-between; padding:14rpx 0; border-bottom:1rpx solid var(--line); font-size:26rpx; color:var(--ink); }
.report-row.sm { font-size:22rpx; padding:8rpx 0; }
.report-row.total { font-weight:800; font-size:30rpx; border-top:2rpx solid var(--ink); }
.report-row.total.net { color:var(--green-800); }
.report-row .ok { color:var(--green-700); }
.report-sub { display:block; margin-top:20rpx; color:var(--muted); font-size:22rpx; font-weight:700; }
.report-breakdown { margin-top:8rpx; }
.month-input { width:200rpx; text-align:center; margin-bottom:16rpx; }
.picker-mask { position:fixed; inset:0; z-index:100; display:flex; align-items:flex-end; justify-content:center; background:rgba(0,0,0,.4); }
.picker-sheet { width:100%; max-width:640rpx; max-height:1200rpx; overflow-y:auto; padding:36rpx 28rpx 52rpx; background:var(--paper); border-radius:32rpx 32rpx 0 0; }
.picker-title { display:block; color:var(--ink); font-size:30rpx; font-weight:800; margin-bottom:20rpx; }
.picker-actions { display:flex; gap:14rpx; margin-top:24rpx; }
.picker-actions .btn-secondary,.picker-actions .btn-primary { flex:1; }
.form-input { width:100%; height:72rpx; margin-bottom:14rpx; padding:0 20rpx; color:var(--ink); font-size:26rpx; background:var(--green-50); border:2rpx solid var(--line); border-radius:16rpx; box-sizing:border-box; }
.type-row { display:flex; flex-wrap:wrap; gap:10rpx; margin-bottom:14rpx; }
.type-chip { padding:10rpx 18rpx; color:var(--muted); background:var(--paper); border:2rpx solid var(--line); border-radius:14rpx; font-size:21rpx; }
.type-chip.active { color:#fff; background:var(--green-700); border-color:var(--green-700); }
.link { color:var(--green-800); font-weight:700; }
.empty-state { padding:38rpx; text-align:center; color:var(--muted); font-size:24rpx; }

.form-label { display:block; margin:2rpx 0 10rpx; color:var(--muted); font-size:22rpx; font-weight:700; }
.payment-row { margin-bottom:16rpx; }
.picker-actions button[disabled] { opacity:.6; }

/* 2026 统一设计升级：财务驾驶舱 */
.fin-page { padding: 0 28rpx 90rpx; }
.fin-hero { margin: 0 -28rpx; padding: 34rpx 32rpx 28rpx; border-radius: 0 0 30rpx 30rpx; }
.fin-hero .hero-desc { display: block; margin-top: 10rpx; color: rgba(255,255,255,.68); font-size: 21rpx; }
.fin-hero-metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8rpx; margin-top: 24rpx; padding: 16rpx 8rpx; background: rgba(255,255,255,.1); border: 1rpx solid rgba(255,255,255,.14); border-radius: 20rpx; }
.fin-hero-metrics view { text-align: center; border-right: 1rpx solid rgba(255,255,255,.12); }
.fin-hero-metrics view:last-child { border-right: 0; }
.fin-hero-num { display: block; color: var(--corn); font-family: var(--font-num); font-size: 29rpx; font-weight: 850; }
.fin-hero-label { display: block; margin-top: 5rpx; color: rgba(255,255,255,.65); font-size: 18rpx; }
.fin-tabs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin: 20rpx 0 24rpx; padding: 5rpx; background: var(--paper-2); border-radius: 18rpx; overflow: visible; }
.fin-tabs .tab-chip { padding: 14rpx 8rpx; text-align: center; background: transparent; border: 0; border-radius: 14rpx; }
.fin-tabs .tab-chip.active { color: var(--green-800); background: var(--paper); box-shadow: var(--shadow-sm); }
.filter-chips { display: flex; align-items: center; gap: 8rpx; margin-bottom: 18rpx; padding: 10rpx; overflow-x: auto; background: var(--paper); border: 1rpx solid var(--ring); border-radius: 18rpx; }
.fin-page .cat-list, .fin-page .report-card { border: 1.5rpx solid var(--ring); box-shadow: var(--shadow-sm); }
.fin-page .cat-item { padding: 22rpx 20rpx; }
.fin-page .empty-state { margin-top: 12rpx; padding: 56rpx 32rpx; background: var(--paper); border: 2rpx dashed var(--line); border-radius: 22rpx; }
.report-row.total { margin-top: 6rpx; padding-top: 18rpx; border-top-color: var(--green-700); }

.recon-toolbar { display: flex; flex-wrap: wrap; align-items: center; gap: 12rpx; margin-bottom: 18rpx; padding: 18rpx; background: var(--paper); border: 1.5rpx solid var(--ring); border-radius: 20rpx; }
.recon-date { min-width: 210rpx; padding: 13rpx 16rpx; color: var(--ink); background: var(--green-50); border: 1rpx solid var(--line); border-radius: 12rpx; font-size: 23rpx; font-weight: 700; }
.recon-channel { display: flex; gap: 8rpx; }
.recon-channel .type-chip { margin: 0; }
.recon-upload { min-width: 180rpx; height: 64rpx; margin: 0 0 0 auto; padding: 0 20rpx; color: #fff; background: var(--green-700); border-radius: 14rpx; font-size: 23rpx; font-weight: 750; line-height: 64rpx; }
.recon-upload::after,.recon-resolve::after { border: 0; }
.recon-summary { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rpx; margin-bottom: 18rpx; overflow: hidden; background: var(--line); border: 1.5rpx solid var(--ring); border-radius: 20rpx; }
.recon-summary view { padding: 18rpx; background: var(--paper); }
.recon-summary-label { display: block; color: var(--muted); font-size: 19rpx; }
.recon-summary-value { display: block; margin-top: 5rpx; color: var(--ink); font-family: var(--font-num); font-size: 28rpx; font-weight: 850; }
.recon-summary.status-exception .recon-summary-value { color: #b54135; }
.recon-list { display: flex; flex-direction: column; gap: 12rpx; }
.recon-item { padding: 20rpx; background: var(--paper); border: 1.5rpx solid var(--ring); border-radius: 20rpx; box-shadow: var(--shadow-sm); }
.recon-item.selected { border-color: var(--green-600); }
.recon-item-head,.recon-item-foot { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.recon-item-title { color: var(--ink); font-size: 25rpx; font-weight: 800; }
.recon-status { padding: 5rpx 12rpx; color: var(--muted); background: var(--paper-2); border-radius: 10rpx; font-size: 18rpx; font-weight: 750; }
.recon-status.balanced { color: var(--green-800); background: var(--green-50); }
.recon-status.exception { color: #b54135; background: rgba(201,67,51,.08); }
.recon-status.resolved { color: #7a5a16; background: rgba(243,168,59,.14); }
.recon-item-money { display: flex; flex-wrap: wrap; gap: 8rpx 18rpx; margin: 13rpx 0; color: var(--ink-2); font-family: var(--font-num); font-size: 21rpx; }
.recon-item-foot { color: var(--muted); font-size: 18rpx; }
.recon-rerun { flex: 0 0 auto; color: var(--green-800); font-weight: 750; }
.recon-differences { margin-top: 20rpx; padding: 20rpx; background: var(--paper); border: 1.5rpx solid var(--ring); border-radius: 20rpx; }
.recon-clear { padding: 30rpx 0 12rpx; text-align: center; color: var(--green-700); font-size: 22rpx; }
.recon-diff { display: flex; align-items: center; gap: 14rpx; padding: 16rpx 0; border-bottom: 1rpx solid var(--line); }
.recon-diff:last-child { border-bottom: 0; }
.recon-diff-main { flex: 1; min-width: 0; }
.recon-diff-type { display: block; color: var(--ink); font-size: 23rpx; font-weight: 800; }
.recon-diff-ref,.recon-diff-money { display: block; margin-top: 4rpx; overflow: hidden; color: var(--muted); font-size: 18rpx; text-overflow: ellipsis; white-space: nowrap; }
.recon-resolve { width: 100rpx; height: 56rpx; margin: 0; padding: 0; color: #fff; background: var(--green-700); border-radius: 12rpx; font-size: 21rpx; line-height: 56rpx; }
.recon-done { color: var(--green-700); font-size: 20rpx; font-weight: 750; }
