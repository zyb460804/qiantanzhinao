/* 批次追溯页 */
.trace-page { min-height:100%; padding:0; background:var(--bg); }
.trace-loading { display:flex; flex-direction:column; align-items:center; justify-content:center; padding-top:200rpx; }
.trace-spinner { width:64rpx; height:64rpx; border:4rpx solid var(--line); border-top-color:var(--green-700); border-radius:50%; animation:spin .8s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }
.loading-text { margin-top:24rpx; color:var(--muted); font-size:26rpx; }

.trace-error { display:flex; flex-direction:column; align-items:center; padding:120rpx 40rpx; }
.error-icon { font-size:80rpx; margin-bottom:24rpx; }
.error-title { font-size:34rpx; font-weight:800; color:var(--ink); margin-bottom:12rpx; }
.error-desc { font-size:24rpx; color:var(--muted); text-align:center; margin-bottom:32rpx; }
.retry-btn { padding:16rpx 48rpx; font-size:26rpx; font-weight:700; color:#fff; background:var(--green-700); border-radius:99rpx; border:none; }

/* Banner */
.trace-banner { display:flex; flex-direction:column; align-items:center; padding:40rpx 32rpx; }
.trace-banner.green { background:linear-gradient(135deg,#d4edda,#c3e6cb); }
.trace-banner.amber { background:linear-gradient(135deg,#fff3cd,#ffeaa7); }
.trace-banner.red { background:linear-gradient(135deg,#f8d7da,#f5c6cb); }
.trace-banner.muted { background:var(--line); }
.banner-icon { font-size:52rpx; font-weight:900; margin-bottom:8rpx; }
.banner-label { font-size:36rpx; font-weight:800; color:var(--ink); }
.banner-warn { margin-top:8rpx; font-size:24rpx; color:#c0493d; font-weight:700; }

/* Info card */
.trace-card { margin:20rpx 28rpx; padding:24rpx 28rpx; background:var(--paper); border-radius:24rpx; box-shadow:var(--shadow); }
.trace-card-title { font-size:28rpx; font-weight:800; color:var(--ink); margin-bottom:16rpx; padding-bottom:12rpx; border-bottom:2rpx solid var(--line); }
.trace-row { display:flex; justify-content:space-between; align-items:flex-start; padding:12rpx 0; }
.trace-row:not(:last-child) { border-bottom:1rpx solid var(--line); }
.trace-key { font-size:24rpx; color:var(--muted); flex:0 0 140rpx; }
.trace-val { font-size:24rpx; color:var(--ink); text-align:right; flex:1; word-break:break-all; }
.text-green { color:var(--green-700); font-weight:700; }
.text-red { color:#c0493d; font-weight:700; }
.certs { display:flex; flex-wrap:wrap; gap:8rpx; justify-content:flex-end; }
.cert-tag { padding:4rpx 14rpx; font-size:20rpx; color:var(--green-800); background:var(--green-50); border-radius:8rpx; }

/* Footer */
.trace-footer { display:flex; flex-direction:column; align-items:center; padding:48rpx 28rpx 80rpx; }
.trace-code-label { font-size:22rpx; color:var(--muted); margin-bottom:8rpx; }
.trace-code { font-size:26rpx; font-family:monospace; color:var(--green-800); font-weight:700; letter-spacing:2rpx; }
.trace-hint { margin-top:6rpx; font-size:20rpx; color:var(--muted); }
.trace-meta { margin-top:24rpx; font-size:20rpx; color:var(--muted); }
