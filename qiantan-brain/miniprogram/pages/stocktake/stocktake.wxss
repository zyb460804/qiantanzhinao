/* 库存盘点页面 · 核对实际库存，校准数字孪生 */

.stocktake-page { padding-top: 22rpx; }

/* ── Tab 切换栏 ───────────────────────────────────────── */
.tab-bar { display: flex; gap: 8rpx; margin-bottom: 22rpx; padding: 8rpx; background: var(--paper-2); border-radius: 22rpx; }
.tab-item { flex: 1; min-height: 74rpx; display: flex; align-items: center; justify-content: center; color: var(--muted); border-radius: 16rpx; font-size: 24rpx; font-weight: 650; }
.tab-item.active { color: var(--green-950); background: var(--paper); box-shadow: 0 6rpx 16rpx rgba(18,61,48,.08); }

/* ── 开始盘点 · 启动卡片 ───────────────────────────────────────── */
.start-card { margin-top: 24rpx; padding: 52rpx 32rpx 44rpx; text-align: center; background: var(--paper); border-radius: var(--radius-xl); box-shadow: var(--shadow); animation: card-rise .35s ease both; }
.start-icon-wrap { display: flex; align-items: center; justify-content: center; width: 110rpx; height: 110rpx; margin: 0 auto 26rpx; color: var(--green-800); background: linear-gradient(145deg, var(--green-50), #f3f7f4); border-radius: 30rpx; }
.start-icon { font-size: 54rpx; font-weight: 800; }
.start-title { display: block; color: var(--ink); font-size: 34rpx; font-weight: 720; }
.start-desc { display: block; margin-top: 14rpx; color: var(--muted); font-size: 24rpx; line-height: 1.55; }
.start-btn { margin: 36rpx auto 0; width: 80%; }

/* ── 进度卡片 ───────────────────────────────────────── */
.progress-card { margin-bottom: 22rpx; padding: 26rpx 28rpx; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.progress-head { display: flex; align-items: center; justify-content: space-between; }
.progress-label { color: var(--ink); font-size: 26rpx; font-weight: 700; }
.progress-count { color: var(--green-800); font-size: 32rpx; font-weight: 800; }
.progress-track { height: 14rpx; margin-top: 18rpx; overflow: hidden; background: #ecefe9; border-radius: 99rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, var(--green-800), var(--green-600)); border-radius: 99rpx; transition: width .35s ease; }
.progress-hint { display: block; margin-top: 12rpx; color: var(--muted); font-size: 21rpx; }

/* ── 商品盘点列表 ───────────────────────────────────────── */
.stocktake-list { display: flex; flex-direction: column; gap: 18rpx; }
.stocktake-card { padding: 26rpx; background: var(--paper); border: 1rpx solid transparent; border-radius: var(--radius-lg); box-shadow: 0 8rpx 24rpx rgba(25,48,38,.06); animation: card-rise .32s ease both; }
.stocktake-card.submitted { border-color: rgba(23,92,69,.15); background: #fbfdfb; }

/* 商品头部 */
.item-head { display: flex; justify-content: space-between; align-items: flex-start; }
.item-name-wrap { flex: 1; min-width: 0; }
.item-name { display: block; color: var(--ink); font-size: 33rpx; font-weight: 760; line-height: 1.3; }
.item-tag-row { display: flex; align-items: center; gap: 10rpx; margin-top: 12rpx; }
.mini-tag { padding: 5rpx 14rpx; border-radius: 99rpx; font-size: 19rpx; font-weight: 600; }
.tag-ghost { color: var(--muted); background: #f0f0ea; }

/* 实际数量输入区 */
.qty-input-area { margin-top: 22rpx; }
.qty-input-label { display: block; margin-bottom: 12rpx; color: var(--muted); font-size: 22rpx; }
.qty-input-row { display: flex; align-items: center; gap: 14rpx; }
.qty-input { flex: 1; height: 92rpx; padding: 0 24rpx; color: var(--ink); font-size: 42rpx; font-weight: 800; text-align: center; background: var(--canvas); border: 2rpx solid var(--line); border-radius: 18rpx; }
.qty-input-unit { color: var(--muted); font-size: 26rpx; }
.qty-placeholder { color: var(--muted); font-size: 30rpx; font-weight: 500; }

/* 快捷调整按钮 */
.quick-btns { display: flex; gap: 10rpx; margin-top: 16rpx; }
.quick-btn { flex: 1; display: flex; align-items: center; justify-content: center; min-height: 66rpx; color: var(--green-800); background: var(--green-50); border-radius: 14rpx; font-size: 25rpx; font-weight: 720; }
.quick-btn:active { opacity: .78; transform: scale(.97); }

/* 差异显示区域 */
.variance-area { margin-top: 18rpx; padding: 16rpx 20rpx; background: #f8f7f1; border-radius: 16rpx; }
.variance-row { display: flex; align-items: center; gap: 14rpx; }
.variance-label { color: var(--muted); font-size: 23rpx; }
.variance-value { font-size: 30rpx; font-weight: 780; }
.variance-text { padding: 5rpx 14rpx; border-radius: 99rpx; font-size: 22rpx; font-weight: 650; }
.variance-value.gain, .variance-text.gain { color: var(--green-700); }
.variance-text.gain { background: var(--green-100); }
.variance-value.loss, .variance-text.loss { color: var(--red); }
.variance-text.loss { background: var(--red-soft); }
.variance-value.zero, .variance-text.zero { color: var(--muted); }
.variance-text.zero { background: #eeeee8; }
.variance-pending { color: var(--amber); font-size: 24rpx; font-weight: 650; }

/* 差异原因选择器 */
.reason-area { margin-top: 16rpx; }
.reason-label { display: block; margin-bottom: 10rpx; color: var(--muted); font-size: 22rpx; }
.reason-btns { display: flex; flex-wrap: wrap; gap: 10rpx; }
.reason-btn { padding: 13rpx 22rpx; color: var(--ink-2); background: #f2f2ec; border: 1rpx solid var(--line); border-radius: 99rpx; font-size: 22rpx; font-weight: 600; }
.reason-btn.active { color: #fff; background: var(--green-800); border-color: var(--green-800); }
.reason-btn:active { opacity: .82; transform: scale(.97); }

/* ── 底部固定汇总栏 ───────────────────────────────────────── */
.bottom-bar { position: fixed; left: 0; right: 0; bottom: 0; z-index: 50; padding: 18rpx 24rpx 14rpx; background: var(--paper); border-top: 1rpx solid var(--line); box-shadow: 0 -8rpx 24rpx rgba(25,48,38,.06); }
.bottom-summary { display: flex; align-items: center; justify-content: space-around; margin-bottom: 16rpx; }
.bottom-stat { text-align: center; flex: 1; }
.bottom-stat-num { display: block; color: var(--ink); font-size: 30rpx; font-weight: 800; }
.bottom-stat-num.loss { color: var(--red); }
.bottom-stat-num.gain { color: var(--green-700); }
.bottom-stat-num.muted { color: var(--muted); }
.bottom-stat-label { display: block; margin-top: 4rpx; color: var(--muted); font-size: 19rpx; }
.bottom-divider { width: 1rpx; height: 48rpx; background: var(--line); }
.bottom-complete { width: 100%; }
.bottom-complete.disabled { opacity: .5; }
.bottom-placeholder { height: 220rpx; }

/* ── 盘点完成结果 ───────────────────────────────────────── */
.result-hero { background: var(--green-950); }
.result-card { margin-top: 22rpx; padding: 28rpx; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.result-card-head { margin-bottom: 18rpx; }
.result-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.result-item { padding: 22rpx; background: var(--canvas); border-radius: var(--radius-md); text-align: center; }
.result-num { display: block; color: var(--ink); font-size: 40rpx; font-weight: 820; }
.result-num.loss { color: var(--red); }
.result-num.gain { color: var(--green-700); }
.result-label { display: block; margin-top: 6rpx; color: var(--muted); font-size: 22rpx; }

/* 调整明细 */
.adjust-list { display: flex; flex-direction: column; gap: 12rpx; }
.adjust-card { padding: 22rpx 24rpx; background: var(--paper); border-radius: var(--radius-md); box-shadow: 0 6rpx 18rpx rgba(25,48,38,.04); animation: card-rise .3s ease both; }
.adjust-head { display: flex; justify-content: space-between; align-items: center; }
.adjust-name { color: var(--ink); font-size: 27rpx; font-weight: 720; }
.adjust-variance { font-size: 28rpx; font-weight: 780; }
.adjust-variance.loss { color: var(--red); }
.adjust-variance.gain { color: var(--green-700); }
.adjust-detail { margin-top: 8rpx; }
.adjust-meta { color: var(--muted); font-size: 21rpx; }

/* 结果操作按钮 */
.result-actions { display: flex; gap: 16rpx; margin-top: 32rpx; }
.result-actions button { flex: 1; }
.new-stocktake-link { margin-top: 24rpx; text-align: center; color: var(--green-700); font-size: 23rpx; font-weight: 600; }
.new-stocktake-link:active { opacity: .68; }

/* ── 盘点历史 ───────────────────────────────────────── */
.history-list { display: flex; flex-direction: column; gap: 16rpx; }
.history-card { padding: 26rpx; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); animation: card-rise .32s ease both; }
.history-head { display: flex; justify-content: space-between; align-items: center; }
.history-date { color: var(--ink); font-size: 28rpx; font-weight: 720; }
.history-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12rpx; margin-top: 18rpx; padding-top: 18rpx; border-top: 1rpx solid var(--line); }
.history-stat { text-align: center; }
.history-stat-num { display: block; color: var(--ink); font-size: 26rpx; font-weight: 760; }
.history-stat-num.loss { color: var(--red); }
.history-stat-num.gain { color: var(--green-700); }
.history-stat-label { display: block; margin-top: 4rpx; color: var(--muted); font-size: 19rpx; }
.history-notes { margin-top: 14rpx; padding: 14rpx 16rpx; background: var(--canvas); border-radius: 14rpx; }
.history-notes-text { color: var(--ink-2); font-size: 22rpx; line-height: 1.5; }

/* ── 动画 ───────────────────────────────────────── */
@keyframes card-rise { from { opacity: 0; transform: translateY(12rpx); } to { opacity: 1; transform: translateY(0); } }
.mascot-empty { display: flex; justify-content: center; align-items: center; margin: 0 auto var(--s-2); }

/* 2026 统一设计升级：盘点工作流 */
.stocktake-page { padding: 0 28rpx 100rpx; }
.stocktake-hero { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; margin: 0 -28rpx; padding: 34rpx 32rpx 30rpx; border-radius: 0 0 30rpx 30rpx; }
.stocktake-hero .hero-desc { display: block; max-width: 460rpx; margin-top: 10rpx; color: rgba(255,255,255,.68); font-size: 21rpx; }
.stocktake-hero-mark { display: flex; align-items: center; justify-content: center; width: 98rpx; height: 98rpx; flex: 0 0 auto; color: var(--corn); background: rgba(255,255,255,.11); border: 1rpx solid rgba(255,255,255,.16); border-radius: 28rpx; font-size: 43rpx; font-weight: 850; }
.stocktake-tabs { position: static; display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin: 20rpx 0 24rpx; padding: 5rpx; background: var(--paper-2); border: 0; border-radius: 18rpx; }
.stocktake-tabs .tab-item { padding: 14rpx 10rpx; text-align: center; border-radius: 14rpx; }
.stocktake-tabs .tab-item.active { color: var(--green-800); background: var(--paper); box-shadow: var(--shadow-sm); }
.stocktake-tabs .tab-item.active::after { display: none; }
.start-card { margin-top: 0; border: 1.5rpx solid var(--ring); box-shadow: var(--shadow-sm); }
.progress-card, .stocktake-card, .result-card, .history-card { border: 1.5rpx solid var(--ring); box-shadow: var(--shadow-sm); }
.qty-input-area { background: var(--green-50); border-radius: 18rpx; }
.quick-btn { min-height: 62rpx; }
.bottom-bar { background: rgba(255,254,250,.96); }
