.voice-page { padding-top: 22rpx; }
.voice-hero { min-height: 270rpx; }
.voice-hero-top { position: relative; z-index: 2; display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; }
.today-chip { position: absolute; z-index: 2; right: 28rpx; bottom: 24rpx; display: flex; align-items: baseline; gap: 8rpx; padding: 10rpx 16rpx; color: rgba(255,255,255,.72); background: rgba(255,255,255,.1); border-radius: 999rpx; font-size: 21rpx; }
.chip-number { font-family: var(--font-num); font-size: 31rpx; font-weight: 800; color: var(--corn); }

.mode-switch { display: grid; grid-template-columns: 1fr 1fr; gap: 8rpx; margin-top: 22rpx; padding: 8rpx; background: var(--paper-2); border-radius: 22rpx; }
.mode-option { display: flex; align-items: center; justify-content: center; gap: 12rpx; min-height: 78rpx; color: var(--muted); border-radius: 17rpx; font-size: 25rpx; font-weight: 650; }
.mode-option.active { color: var(--green-950); background: var(--paper); box-shadow: 0 6rpx 16rpx rgba(18,61,48,.08); }

.voice-stage { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 480rpx; }

/* 声波纹 */
.wave-wrap { display: flex; align-items: center; justify-content: center; gap: 10rpx; height: 90rpx; margin-bottom: 6rpx; opacity: .25; transition: opacity var(--dur-fast); }
.wave-wrap.on { opacity: 1; }
.wave-bar { width: 10rpx; height: 18rpx; border-radius: 999rpx; background: var(--green-600); }
.wave-wrap.on .wave-bar { animation: wave 1.1s var(--ease-spring) infinite; animation-delay: calc(var(--i) * 70ms); }
@keyframes wave { 0%,100% { height: 16rpx; } 50% { height: 78rpx; } }

.voice-rings { display: flex; align-items: center; justify-content: center; width: 380rpx; height: 380rpx; background: radial-gradient(circle, rgba(31,114,85,.11) 0, rgba(31,114,85,.06) 52%, transparent 53%); border-radius: 50%; }
.stage-tip { max-width: 580rpx; margin-top: 14rpx; color: var(--muted); text-align: center; font-size: 24rpx; }
.stage-tip.active { color: var(--green-700); font-weight: 650; }

/* 流式字幕 */
.subtitle { display: flex; align-items: center; gap: 16rpx; margin-top: 18rpx; padding: 22rpx 24rpx; background: var(--green-50); border: 2rpx solid var(--green-200); border-radius: var(--radius-lg); }
.subtitle-text { flex: 1; color: var(--ink); font-size: 27rpx; line-height: 1.55; }
.caret { color: var(--corn); animation: blink 1s step-end infinite; }
@keyframes blink { 50% { opacity: 0; } }

.text-panel { margin-top: 22rpx; padding: 28rpx; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.input-head { display: flex; align-items: center; justify-content: space-between; font-size: 27rpx; font-weight: 700; }
.input-count { color: var(--muted); font-size: 21rpx; font-weight: 500; }
.text-input { width: 100%; min-height: 210rpx; margin: 22rpx 0; padding: 22rpx; color: var(--ink); background: var(--paper-2); border: 2rpx solid transparent; border-radius: 18rpx; font-size: 29rpx; line-height: 1.65; }
.submit-text[disabled] { opacity: .45; }

.asr-card { margin-top: 12rpx; padding: 25rpx 28rpx; background: #eef4f1; border-left: 7rpx solid var(--green-700); border-radius: 8rpx var(--radius-lg) var(--radius-lg) 8rpx; }
.asr-head { display: flex; align-items: center; gap: 10rpx; color: var(--green-700); font-size: 22rpx; font-weight: 700; }
.asr-dot { width: 10rpx; height: 10rpx; background: var(--green-700); border-radius: 50%; }
.asr-text { display: block; margin-top: 11rpx; color: var(--ink); font-size: 29rpx; line-height: 1.65; }

.error-panel { display: flex; align-items: center; gap: 18rpx; margin-top: 20rpx; padding: 22rpx; background: var(--red-soft); border-radius: var(--radius-lg); }
.error-copy { flex: 1; }
.error-title, .error-desc { display: block; }
.error-title { color: #943b35; font-weight: 700; }
.error-desc { margin-top: 3rpx; color: #a86661; font-size: 21rpx; }
.retry-btn { padding: 14rpx 20rpx; color: #943b35; background: rgba(255,255,255,.58); border-radius: 14rpx; font-size: 23rpx; font-weight: 700; }

.recent-list { overflow: hidden; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.recent-item { display: flex; align-items: center; gap: 18rpx; padding: 22rpx 24rpx; border-bottom: 1rpx solid var(--line); }
.recent-item:last-child { border-bottom: 0; }
.recent-index { color: var(--green-700); font-family: monospace; font-size: 22rpx; font-weight: 800; }
.recent-text { flex: 1; color: var(--ink-2); font-size: 24rpx; }
.recent-status { display: flex; align-items: center; gap: 10rpx; flex-shrink: 0; }
.recent-tag { display: inline-flex; align-items: center; min-height: 36rpx; padding: 0 12rpx; border-radius: 999rpx; font-size: 19rpx; font-weight: 650; }
.void-btn { color: var(--red); font-size: 22rpx; font-weight: 650; padding: 8rpx 16rpx; background: var(--red-soft); border-radius: 12rpx; }

.reduce-motion .wave-bar,
.reduce-motion .caret { animation: none !important; }
