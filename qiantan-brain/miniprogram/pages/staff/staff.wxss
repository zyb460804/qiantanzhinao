/* ── 员工管理 — 复用全局 .btn-* / .form-field / .dialog / .empty-state ── */
.staff-hero { background: linear-gradient(135deg, var(--green-950), var(--green-800)); color: #fff; }

.staff-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 32rpx; gap: 16rpx;
}
.toolbar-hint { font-size: var(--fs-sm); color: var(--ink-2); }
.toolbar-hint.muted { color: var(--muted); }

/* 员工卡片 — 描边立层次（遵守设计系统核心原则） */
.staff-card {
  margin: 0 24rpx 16rpx; padding: 0;
  background: var(--paper); border: 1.5rpx solid var(--ring); border-radius: var(--r-lg);
  box-shadow: var(--shadow-sm); overflow: hidden;
  transition: box-shadow var(--dur-fast), border-color var(--dur-fast);
}
.staff-card.expanded { box-shadow: var(--shadow); border-color: var(--green-200); }

.staff-row {
  display: flex; align-items: center; padding: 24rpx 28rpx; gap: 20rpx;
}
.staff-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: var(--fs-base); font-weight: 700; color: #fff;
  flex-shrink: 0;
}
.staff-avatar.owner { background: var(--green-700); }
.staff-avatar.manager { background: var(--green-600); }
.staff-avatar.cashier { background: var(--corn); color: var(--corn-ink); }
.staff-avatar.purchaser { background: var(--info); }
.staff-avatar.stocker { background: var(--grape); }
.staff-avatar.market_admin { background: var(--tomato); }

.staff-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; min-width: 0; }
.staff-name { font-size: 30rpx; font-weight: 600; color: var(--ink); }
.staff-role-tag {
  display: inline-block; font-size: var(--fs-xs); padding: 4rpx 16rpx; border-radius: var(--r-pill);
  color: #fff; align-self: flex-start;
}
.staff-role-tag.owner { background: var(--green-700); }
.staff-role-tag.manager { background: var(--green-600); }
.staff-role-tag.cashier { background: var(--corn); color: var(--corn-ink); }
.staff-role-tag.purchaser { background: var(--info); }
.staff-role-tag.stocker { background: var(--grape); }
.staff-role-tag.market_admin { background: var(--tomato); }

.staff-arrow { font-size: var(--fs-base); color: var(--muted); flex-shrink: 0; }

/* 展开区 */
.staff-detail {
  padding: 0 28rpx 24rpx; border-top: 1rpx solid var(--line-soft);
  display: flex; flex-direction: column; gap: 16rpx;
}
.detail-row { display: flex; gap: 16rpx; align-items: center; }
.detail-label { font-size: var(--fs-sm); color: var(--muted); }
.detail-value { font-size: var(--fs-base); color: var(--ink); }
.perm-head { margin-top: 4rpx; }

.perm-tags { display: flex; flex-wrap: wrap; gap: 10rpx; }
.perm-tag {
  font-size: var(--fs-xs); padding: 6rpx 16rpx; border-radius: var(--r-sm);
  background: var(--green-50); color: var(--green-800);
}
.perm-tag.danger { background: var(--tomato-soft); color: var(--tomato-ink); }

.detail-actions { display: flex; gap: 16rpx; margin-top: 8rpx; }

/* 弹窗 / 表单 / 按钮 / 空态：统一复用全局 .dialog / .form-field / .btn-* / .empty-state */
