<!-- 员工管理 — 列表·新增·编辑·停用·权限查看 -->
<wxs module="S">
  var ROLES = ['owner','manager','cashier','purchaser','stocker','market_admin'];
  var ROLE_LABELS = { owner:'摊主', manager:'经理', cashier:'收银员', purchaser:'采购员', stocker:'理货员', market_admin:'市场管理' };
  var PERM_LABELS = {
    view_profit:'查看利润', change_price:'修改价格', purchase_confirm:'确认采购',
    supplier_payment:'供应商付款', credit_sale:'赊账销售', order_refund:'订单退款',
    inventory_adjust:'库存调整', record_waste:'记录损耗', daily_settle:'日结锁定',
    void_record:'作废记录', export_data:'导出数据', manage_staff:'管理员工',
    batch_lock:'锁定批次', batch_destroy:'销毁批次'
  };
  module.exports = {
    roleLabel: function(r) { return ROLE_LABELS[r] || r; },
    roleIndex: function(r) {
      for (var i = 0; i < ROLES.length; i++) { if (ROLES[i] === r) return i; }
      return 2;
    },
    permLabel: function(p) { return PERM_LABELS[p] || p; },
    isDanger: function(p) {
      if (p === 'void_record') return true;
      if (p === 'batch_destroy') return true;
      if (p === 'order_refund') return true;
      return false;
    }
  };
</wxs>

<view class="page-shell staff-page {{skinClass}}">

  <!-- Hero -->
  <view class="page-hero staff-hero">
    <text class="eyebrow">STAFF · 团队协作</text>
    <text class="hero-title">员工管理</text>
    <text class="hero-desc">管理店员角色与操作权限</text>
  </view>

  <!-- 操作栏 -->
  <view class="staff-toolbar">
    <text class="toolbar-hint" wx:if="{{staffList.length > 0}}">共 {{staffList.length}} 位员工</text>
    <text class="toolbar-hint muted" wx:else>暂未添加员工</text>
    <button class="btn-primary btn-sm" bindtap="openForm" data-mode="create">+ 添加员工</button>
  </view>

  <!-- 加载态 / 错误态 -->
  <view class="empty-state surface" wx:if="{{loading}}">
    <view class="sk-line w60"></view>
    <view class="sk-line w40"></view>
  </view>
  <view class="empty-state surface" wx:elif="{{loadError}}">
    <mascot size="md" mood="idle"/>
    <text class="empty-title">数据加载失败</text>
    <button class="btn-ghost btn-sm" bindtap="loadAll">重试</button>
  </view>

  <!-- 员工列表 -->
  <block wx:else>
    <view class="staff-list">
      <view wx:for="{{staffList}}" wx:key="staff_id" class="staff-card {{expandedId === item.staff_id ? 'expanded' : ''}}">
        <!-- 主行 -->
        <view class="staff-row" data-id="{{item.staff_id}}" bindtap="toggleExpand">
          <view class="staff-avatar {{item.role}}"></view>
          <view class="staff-info">
            <text class="staff-name">{{item.name}}</text>
            <text class="staff-role-tag {{item.role}}">{{S.roleLabel(item.role)}}</text>
          </view>
          <text class="staff-arrow">{{expandedId === item.staff_id ? '▾' : '▸'}}</text>
        </view>

        <!-- 展开：权限明细 + 操作 -->
        <view class="staff-detail" wx:if="{{expandedId === item.staff_id}}">
          <view class="detail-row" wx:if="{{item.phone}}">
            <text class="detail-label">手机号</text><text class="detail-value">{{item.phone}}</text>
          </view>
          <text class="detail-label perm-head">操作权限 ({{item.permissions.length}} 项)</text>
          <view class="perm-tags">
            <text wx:for="{{item.permissions}}" wx:for-item="p" wx:key="*this" class="perm-tag {{S.isDanger(p) ? 'danger' : ''}}">{{S.permLabel(p)}}</text>
          </view>
          <view class="detail-actions">
            <button class="btn-ghost btn-sm" data-id="{{item.staff_id}}" data-mode="edit" catchtap="openForm">编辑</button>
            <button class="btn-tomato btn-sm" data-id="{{item.staff_id}}" catchtap="deactivate">停用</button>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 新增/编辑弹窗 -->
  <view class="dialog-mask" wx:if="{{formVisible}}" catchtap="closeForm">
    <view class="dialog" catchtap="stopMaskTap">
      <text class="dialog-title">{{formMode === 'create' ? '添加员工' : '编辑员工'}}</text>

      <view class="form-field">
        <text class="form-label">姓名 <text class="required">*</text></text>
        <input class="form-input" placeholder="员工姓名" value="{{form.name}}" data-field="name" bindinput="onFormField" maxlength="20" />
      </view>
      <view class="form-field">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" placeholder="选填" value="{{form.phone}}" data-field="phone" bindinput="onFormField" maxlength="11" />
      </view>
      <view class="form-field">
        <text class="form-label">角色</text>
        <picker mode="selector" value="{{S.roleIndex(form.role)}}" range="{{['摊主','经理','收银员','采购员','理货员','市场管理']}}" data-field="role" bindchange="onFormField">
          <view class="form-picker">{{S.roleLabel(form.role)}}</view>
        </picker>
      </view>
      <view class="form-field">
        <text class="form-label">PIN 码</text>
        <input class="form-input" type="number" placeholder="4-6位数字, 可选" value="{{form.pin_code}}" data-field="pin_code" bindinput="onFormField" maxlength="6" />
      </view>

      <view class="dialog-actions">
        <button class="btn-secondary" bindtap="closeForm" disabled="{{formSubmitting}}">取消</button>
        <button class="btn-primary" bindtap="submitForm" disabled="{{formSubmitting}}" loading="{{formSubmitting}}">{{formMode === 'create' ? '添加' : '保存'}}</button>
      </view>
    </view>
  </view>

</view>
