.dev-page { padding-bottom:100rpx; }
.tab-row { display:flex; gap:12rpx; margin:16rpx 0; overflow-x:auto; }
.tab-chip { padding:14rpx 24rpx; color:var(--muted); background:var(--paper); border:2rpx solid var(--line); border-radius:99rpx; font-size:24rpx; font-weight:700; white-space:nowrap; flex:0 0 auto; }
.tab-chip.active { color:#fff; background:var(--green-700); border-color:var(--green-700); }
.cat-list { overflow:hidden; background:var(--paper); border-radius:24rpx; box-shadow:var(--shadow); margin-bottom:20rpx; }
.cat-item { display:flex; align-items:center; padding:20rpx 24rpx; border-bottom:1rpx solid var(--line); gap:12rpx; }
.cat-item:last-child { border-bottom:none; }
.cat-main { flex:1; min-width:0; }
.cat-name { display:block; color:var(--ink); font-size:27rpx; font-weight:750; }
.cat-meta { display:block; margin-top:4rpx; color:var(--muted); font-size:20rpx; }
.cat-actions { display:flex; gap:8rpx; flex:0 0 auto; }
.act-btn { padding:6rpx 14rpx; color:var(--green-800); background:var(--green-50); border-radius:99rpx; font-size:20rpx; }
.act-btn:active { opacity:.7; }
.act-btn.del { color:#c0493d; background:rgba(201,67,51,.08); }
.type-row { display:flex; gap:10rpx; margin-bottom:14rpx; }
.type-chip { padding:10rpx 18rpx; color:var(--muted); background:var(--paper); border:2rpx solid var(--line); border-radius:14rpx; font-size:21rpx; }
.type-chip.active { color:#fff; background:var(--green-700); border-color:var(--green-700); }
.picker-mask { position:fixed; inset:0; z-index:100; display:flex; align-items:flex-end; justify-content:center; background:rgba(0,0,0,.4); }
.picker-sheet { width:100%; max-width:640rpx; max-height:1200rpx; overflow-y:auto; padding:36rpx 28rpx 52rpx; background:var(--paper); border-radius:32rpx 32rpx 0 0; }
.picker-title { display:block; color:var(--ink); font-size:30rpx; font-weight:800; margin-bottom:20rpx; }
.picker-actions { display:flex; gap:14rpx; margin-top:24rpx; }
.picker-actions .btn-secondary,.picker-actions .btn-primary { flex:1; }
.form-input { width:100%; height:72rpx; margin-bottom:14rpx; padding:0 20rpx; color:var(--ink); font-size:26rpx; background:var(--green-50); border:2rpx solid var(--line); border-radius:16rpx; box-sizing:border-box; }
.link { color:var(--green-800); font-weight:700; }
.empty-state { padding:38rpx; text-align:center; color:var(--muted); font-size:24rpx; }
.name-row { display:flex; align-items:center; gap:10rpx; }
.status-badge { padding:3rpx 10rpx; border-radius:99rpx; font-size:18rpx; }
.status-badge.active { color:var(--green-800); background:var(--green-50); }
.status-badge.off { color:var(--muted); background:rgba(127,127,127,.12); }
.cat-item.inactive { opacity:.68; }
.load-warning { margin:12rpx 0; padding:16rpx 20rpx; color:#9a5b00; background:#fff5dc; border-radius:16rpx; font-size:22rpx; text-align:center; }
.link-btn { margin:0; padding:0 12rpx; min-height:52rpx; line-height:52rpx; color:var(--green-800); background:transparent; border:none; font-size:24rpx; font-weight:700; }
.link-btn::after { border:none; }

/* 2026 统一设计升级：设备中心 */
.dev-page { padding: 0 28rpx 90rpx; }
.dev-hero { display: flex; align-items: flex-end; justify-content: space-between; gap: 20rpx; margin: 0 -28rpx; padding: 34rpx 32rpx 30rpx; border-radius: 0 0 30rpx 30rpx; }
.dev-hero .hero-desc { display: block; max-width: 430rpx; margin-top: 10rpx; color: rgba(255,255,255,.68); font-size: 21rpx; line-height: 1.45; }
.hero-device-count { display: flex; flex: 0 0 auto; flex-direction: column; align-items: center; min-width: 126rpx; padding: 16rpx; color: rgba(255,255,255,.68); background: rgba(255,255,255,.11); border: 1rpx solid rgba(255,255,255,.16); border-radius: 20rpx; font-size: 19rpx; }
.hero-device-num { color: var(--corn); font-family: var(--font-num); font-size: 44rpx; font-weight: 850; line-height: 1.05; }
.dev-overview { display: flex; align-items: center; margin: 20rpx 0; padding: 20rpx 12rpx; background: var(--paper); border: 1.5rpx solid var(--ring); border-radius: 22rpx; box-shadow: var(--shadow-sm); }
.overview-cell { flex: 1; text-align: center; }
.overview-num { display: block; color: var(--ink); font-family: var(--font-num); font-size: 32rpx; font-weight: 850; }
.overview-num.good { color: var(--green-700); }.overview-num.warn { color: var(--red); }
.overview-label { display: block; margin-top: 5rpx; color: var(--muted); font-size: 19rpx; }
.overview-line { width: 1rpx; height: 40rpx; background: var(--line); }
.dev-tabs { display: grid; grid-template-columns: 1fr 1fr; gap: 0; padding: 5rpx; background: var(--paper-2); border-radius: 18rpx; overflow: visible; }
.dev-tabs .tab-chip { padding: 14rpx 12rpx; text-align: center; background: transparent; border: 0; border-radius: 14rpx; }
.dev-tabs .tab-chip.active { background: var(--paper); color: var(--green-800); box-shadow: var(--shadow-sm); }
.dev-page .cat-list { border: 1.5rpx solid var(--ring); box-shadow: var(--shadow-sm); }
.dev-page .cat-item { padding: 24rpx; }
.dev-page .empty-state { margin-top: 12rpx; padding: 58rpx 32rpx; background: var(--paper); border: 2rpx dashed var(--line); border-radius: 22rpx; }
