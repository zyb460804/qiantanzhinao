<view class="page-shell skin-{{skin}} {{dark ? 'ui-dark' : ''}} {{reduce ? 'reduce-motion' : ''}}">
  <view class="skin-ambient-layer"></view>

  <!-- 头部 -->
  <view class="sg-hero page-hero page-hero--breathing">
    <view class="row" style="gap:20rpx;position:relative;z-index:2;">
      <mascot size="md" mood="idle" />
      <view>
        <text class="eyebrow">千摊智脑 · 设计系统</text>
        <text class="hero-title">地基 v2.2</text>
        <text class="hero-desc">市井烟火 × 生鲜元气 — 当前皮肤：{{skinLabel[skin]}}{{dark ? ' · 深色' : ''}}</text>
      </view>
    </view>
  </view>

  <!-- 全局开关 -->
  <view class="sg-controls">
    <view class="sg-control-title">时段皮肤</view>
    <view class="btn-row">
      <view class="chip {{skin==='morning'?'chip--on':''}}" bindtap="setSkin" data-s="morning">🌅 早市</view>
      <view class="chip {{skin==='noon'?'chip--on':''}}" bindtap="setSkin" data-s="noon">☀️ 午市</view>
      <view class="chip {{skin==='evening'?'chip--on':''}}" bindtap="setSkin" data-s="evening">🌇 晚市</view>
    </view>
    <view class="btn-row" style="margin-top:16rpx;">
      <view class="chip {{dark?'chip--on':''}}" bindtap="toggleDark">🌙 深色模式</view>
      <view class="chip {{reduce?'chip--on':''}}" bindtap="toggleReduce">🚫 减少动效</view>
    </view>
  </view>

  <!-- 色彩 -->
  <view class="section-head"><text class="section-title">色彩</text></view>
  <view class="card card--flush">
    <view class="sg-swatch-head">生鲜叶绿（主导）</view>
    <view class="sg-swatches">
      <view wx:for="{{greens}}" wx:key="*this" class="sg-swatch">
        <view class="sg-swatch-color" style="background:var(--{{item}})"></view>
        <text class="sg-swatch-name">{{item}}</text>
      </view>
    </view>
    <view class="sg-swatch-head">点缀 · 番茄红 / 玉米金</view>
    <view class="sg-swatches">
      <view class="sg-swatch"><view class="sg-swatch-color" style="background:var(--tomato)"></view><text class="sg-swatch-name">tomato</text></view>
      <view class="sg-swatch"><view class="sg-swatch-color" style="background:var(--tomato-soft)"></view><text class="sg-swatch-name">tomato-soft</text></view>
      <view class="sg-swatch"><view class="sg-swatch-color" style="background:var(--corn)"></view><text class="sg-swatch-name">corn</text></view>
      <view class="sg-swatch"><view class="sg-swatch-color" style="background:var(--corn-soft)"></view><text class="sg-swatch-name">corn-soft</text></view>
    </view>
    <view class="sg-swatch-head">暖纸中性</view>
    <view class="sg-swatches">
      <view class="sg-swatch" wx:for="{{neutrals}}" wx:key="*this">
        <view class="sg-swatch-color" style="background:var(--{{item}});border:1rpx solid var(--line)"></view>
        <text class="sg-swatch-name">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 字体 -->
  <view class="section-head"><text class="section-title">字体</text></view>
  <view class="card">
    <view class="sg-type-row"><text class="sg-type-label">展示体</text><text class="sg-type-display">得意黑 Smiley Sans</text></view>
    <view class="sg-type-row"><text class="sg-type-label">数字体</text><text class="sg-type-num">¥1,280.50</text></view>
    <view class="sg-type-row"><text class="sg-type-label">正文</text><text class="sg-type-body">老张菜摊 · 今日营业额节节高</text></view>
  </view>

  <!-- 间距 / 圆角 -->
  <view class="section-head"><text class="section-title">间距 & 圆角</text></view>
  <view class="card">
    <view class="sg-space-row" wx:for="{{['s-1','s-2','s-3','s-4','s-6','s-8']}}" wx:key="*this">
      <text class="sg-space-name">{{item}}</text>
      <view class="sg-space-bar" style="width:var(--{{item}})"></view>
    </view>
    <view class="divider"></view>
    <view class="sg-radius-row">
      <view class="sg-radius" style="border-radius:var(--r-sm)">sm</view>
      <view class="sg-radius" style="border-radius:var(--r-md)">md</view>
      <view class="sg-radius" style="border-radius:var(--r-lg)">lg</view>
      <view class="sg-radius" style="border-radius:var(--r-xl)">xl</view>
    </view>
  </view>

  <!-- 组件 -->
  <view class="section-head"><text class="section-title">组件</text></view>
  <view class="card">
    <view class="sg-sub">按钮</view>
    <view class="btn-row" style="margin-bottom:16rpx;">
      <view class="btn-primary">主按钮</view>
      <view class="btn-tomato">语音记账</view>
    </view>
    <view class="btn-row">
      <view class="btn-secondary">次按钮</view>
      <view class="btn-ghost">幽灵</view>
    </view>
  </view>

  <view class="card">
    <view class="sg-sub">标签 / 芯片 / KPI</view>
    <view class="row" style="gap:12rpx;flex-wrap:wrap;margin-bottom:16rpx;">
      <view class="tag tag-green">生鲜</view>
      <view class="tag tag-tomato">语音</view>
      <view class="tag tag-corn">利润</view>
      <view class="chip chip--on"><icon name="leaf" size="sm" color="var(--green-700)"/> 时令</view>
    </view>
    <view class="row-between">
      <view class="kpi"><text class="kpi-value is-green">¥1,280</text><text class="kpi-label">今日营业额</text></view>
      <view class="kpi" style="text-align:right;"><text class="kpi-value is-tomato">¥320</text><text class="kpi-label">净利润</text></view>
    </view>
  </view>

  <view class="card insight">
    <mascot size="sm" mood="think" />
    <view class="insight-body">
      <view class="insight-title">小智今日洞察</view>
      <view class="insight-desc">西红柿剩 2.4 斤，建议降 0.5 元清货，下午补 20 斤。</view>
    </view>
    <view class="btn-sm btn-primary insight-accept">采纳</view>
  </view>

  <view class="card">
    <view class="sg-sub">骨架屏（流光）</view>
    <view class="skeleton sk-line" style="width:60%"></view>
    <view class="skeleton sk-line" style="width:90%"></view>
    <view class="skeleton sk-line" style="width:75%"></view>
  </view>

  <!-- 图标 -->
  <view class="section-head"><text class="section-title">图标</text></view>
  <view class="card">
    <view class="sg-icon-grid">
      <view class="sg-icon-cell" wx:for="{{['leaf','mic','bulb','camera','box','mirror','spark','calendar','trophy','chart','scan','check','cart','refresh','plus']}}" wx:key="*this">
        <icon name="{{item}}" size="lg" />
        <text class="sg-icon-name">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 小智 -->
  <view class="section-head"><text class="section-title">小智 · 吉祥物</text></view>
  <view class="card">
    <view class="sg-mascot-row">
      <view class="sg-mascot-cell"><mascot size="sm" mood="idle" /><text>sm</text></view>
      <view class="sg-mascot-cell"><mascot size="md" mood="think" /><text>think</text></view>
      <view class="sg-mascot-cell"><mascot size="lg" mood="cheer" /><text>cheer</text></view>
    </view>
  </view>

  <view style="height:40rpx;"></view>
</view>
