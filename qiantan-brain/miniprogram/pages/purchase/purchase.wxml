<!-- йҮҮиҙӯжё…еҚ• вҖ” AIе»әи®®вҶ’зј–иҫ‘вҶ’йӘҢж”¶вҶ’е…Ҙеә“вҶ’д»ҳж¬ҫ -->
<wxs src="/utils/format.wxs" module="fmt" />
<view class="page-shell purchase-page {{skinClass}}">

  <!-- Hero -->
  <view class="page-hero purchase-hero">
    <text class="eyebrow">PROCURE В· йҮҮиҙӯйӘҢж”¶</text>
    <text class="hero-title">йҮҮиҙӯжё…еҚ•</text>
    <text class="hero-desc">дёӢеҚ•вҶ’еҲ°иҙ§йӘҢж”¶вҶ’жү№ж¬Ўе…Ҙеә“вҶ’дҫӣеә”е•Ҷд»ҳж¬ҫ</text>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="purchase-skeleton">
    <view class="skel-bar"><view class="skel-line title"></view><view class="skel-line medium"></view></view>
    <view wx:for="{{[1,2,3]}}" wx:key="*this" class="skel-card"><view class="skel-line title"></view><view class="skel-line medium"></view><view class="skel-line"></view><view class="skel-line short"></view></view>
  </view>

  <!-- Empty -->
  <view wx:elif="{{!listData}}" class="empty-state surface empty-purchase">
    <mascot size="lg" mood="idle"></mascot>
    <text class="empty-title">д»Ҡж—ҘиҝҳжІЎжңүйҮҮиҙӯжё…еҚ•</text>
    <text class="empty-desc">д»ҺAIе»әи®®з”ҹжҲҗйҮҮиҙӯжё…еҚ•пјҢеҝ«йҖҹејҖе§Ӣд»Ҡж—ҘйҮҮиҙӯ</text>
    <button class="btn-primary empty-action" bindtap="generateFromAdvice" loading="{{submitting}}">д»ҺAIе»әи®®з”ҹжҲҗ</button>
  </view>

  <!-- List view -->
  <block wx:else>
    <!-- Status bar -->
    <view class="status-bar">
      <view class="status-block">
        <text class="status-label">жё…еҚ•зҠ¶жҖҒ</text>
        <text class="tag {{listData.list_status_tag}}">{{listData.list_status_text}}</text>
      </view>
      <view class="status-divider"></view>
      <view class="status-block">
        <text class="status-label">йў„и®ЎжҖ»йўқ</text>
        <text class="status-amount">ВҘ{{fmt.fixed(listData.total_actual_cost, 2)}}</text>
      </view>
      <view class="status-block" wx:if="{{listData.payment_status}}">
        <text class="status-label">д»ҳж¬ҫ</text>
        <text class="status-amount-sm {{listData.payment_status === 'paid' ? 'ok' : 'warn'}}">{{listData.payment_status === 'paid' ? 'е·Ід»ҳжё…' : listData.payment_status === 'partial' ? 'йғЁеҲҶд»ҳ' : 'жңӘд»ҳ'}}</text>
      </view>
    </view>

    <!-- Section -->
    <view class="section-head">
      <text class="section-title">йҮҮиҙӯйЎ№</text>
      <text class="section-caption">{{listData.item_count}} йЎ№ В· {{listData.purchased_count}} е·Іе…Ҙеә“</text>
      <view wx:if="{{listData.status === 'confirmed' || listData.status === 'accepted'}}" class="section-action" bindtap="enterAcceptance">еҲ°иҙ§йӘҢж”¶</view>
    </view>

    <view wx:if="{{listData.items.length === 0}}" class="empty-state surface">
      <text class="empty-icon">вҲ…</text><text>жё…еҚ•дёәз©ә</text>
      <button class="btn-secondary empty-action" bindtap="generateFromAdvice">йҮҚж–°з”ҹжҲҗ</button>
    </view>

    <!-- Items -->
    <view wx:else class="purchase-list">
      <view wx:for="{{listData.items}}" wx:key="item_id" class="purchase-card {{item.status_class}}">

        <!-- жҷ®йҖҡжЁЎејҸпјҡе•Ҷе“ҒдҝЎжҒҜ + зј–иҫ‘ -->
        <block wx:if="{{!acceptanceMode}}">
          <view class="card-head">
            <view class="card-title-wrap">
              <text class="card-name">{{item.product_name}}</text>
              <text class="tag {{item.status_tag}}">{{item.status_text}}</text>
              <text wx:if="{{item.supplier_name}}" class="supplier-badge">{{item.supplier_name}}</text>
            </view>
            <view wx:if="{{item.editable}}" class="card-actions">
              <text class="action-link" data-id="{{item.item_id}}" bindtap="pickSupplier">{{item.supplier_name ? 'жҚў' : 'йҖүдҫӣеә”е•Ҷ'}}</text>
              <text class="cancel-btn" data-id="{{item.item_id}}" bindtap="cancelItem">еҸ–ж¶Ҳ</text>
            </view>
            <view wx:elif="{{item.status === 'purchased'}}" class="card-actions">
              <text class="action-link return" data-id="{{item.item_id}}" bindtap="openReturn">йҖҖиҙ§</text>
            </view>
          </view>

          <view class="qty-row" wx:if="{{item.editable}}">
            <view class="qty-field"><text class="qty-label">е»әи®®</text><text class="qty-rec">{{fmt.fixed(item.recommended_qty, 1)}}</text><text class="qty-unit">{{item.unit}}</text></view>
            <view class="qty-sep">вҶ’</view>
            <view class="qty-field">
              <text class="qty-label">е®һйҷ…</text>
              <input wx:if="{{editingItemId === item.item_id}}" class="qty-input" type="digit" value="{{item.actual_qty}}" data-id="{{item.item_id}}" data-field="qty" focus="{{true}}" bindinput="editQty" bindblur="saveItem" />
              <view wx:else class="qty-display" data-id="{{item.item_id}}" bindtap="startEdit"><text class="qty-actual">{{fmt.fixed(item.actual_qty, 1)}}</text><text class="qty-unit">{{item.unit}}</text></view>
            </view>
            <view class="deviation {{item.deviation_tone}}" wx:if="{{item.deviation_percent !== 0}}">{{item.deviation_percent > 0 ? '+' : ''}}{{item.deviation_percent}}%</view>
          </view>

          <!-- е·ІйӘҢж”¶ж‘ҳиҰҒ -->
          <view wx:if="{{item.has_acceptance && item.status !== 'cancelled'}}" class="acceptance-summary">
            <text class="acc-sum-label">йӘҢж”¶:</text>
            <text>еҲ°иҙ§{{fmt.fixed(item.arrival_qty,1)}}{{item.unit}}</text>
            <text>еҗҲж ј{{fmt.fixed(item.accepted_qty,1)}}{{item.unit}}</text>
            <text wx:if="{{item.package_count}}">{{item.package_count}}д»¶</text>
            <text wx:if="{{item.shortage_qty > 0}}" class="warn">зјә{{fmt.fixed(item.shortage_qty,1)}}</text>
            <text wx:if="{{item.damaged_qty > 0}}" class="warn">жҚҹ{{fmt.fixed(item.damaged_qty,1)}}</text>
          </view>

          <view class="cost-row" wx:if="{{item.editable}}">
            <view class="cost-field"><text class="cost-label">еҚ•д»·</text><input class="cost-input" type="digit" value="{{item.actual_unit_cost}}" data-id="{{item.item_id}}" data-field="cost" bindinput="editCost" bindblur="saveItem" /></view>
            <view class="cost-field"><text class="cost-label">е°Ҹи®Ў</text><text class="cost-subtotal">ВҘ{{fmt.fixed(item.actual_subtotal, 2)}}</text></view>
          </view>
          <view class="cost-row" wx:elif="{{item.status === 'purchased'}}">
            <view class="cost-field"><text class="cost-label">е…Ҙеә“</text><text class="cost-subtotal">{{fmt.fixed(item.accepted_qty || item.actual_qty, 1)}}{{item.unit}} В· ВҘ{{fmt.fixed(item.actual_unit_cost, 2)}}/{{item.unit}}</text></view>
          </view>

          <view class="reason" wx:if="{{item.reason}}"><text class="reason-tag">AIе»әи®®</text><text class="reason-text">{{item.reason}}</text></view>
        </block>

        <!-- йӘҢж”¶жЁЎејҸ -->
        <block wx:else>
          <view class="card-head">
            <text class="card-name">{{item.product_name}}</text>
            <text class="tag tag-blue" wx:if="{{item.status !== 'cancelled'}}">йӘҢж”¶дёӯ</text>
            <text class="tag tag-muted" wx:else>е·ІеҸ–ж¶Ҳ</text>
          </view>
          <view wx:if="{{item.status !== 'cancelled'}}">
            <!-- еҢ…иЈ…дёҺз§°йҮҚ -->
            <view class="acc-row">
              <view class="acc-field sm"><text class="acc-label">д»¶ж•°</text><input class="acc-input sm" type="number" value="{{acceptanceItems[item.item_id].package_count || ''}}" data-id="{{item.item_id}}" data-field="package_count" bindinput="editAcceptanceField" placeholder="0"/></view>
              <view class="acc-field"><text class="acc-label">жҜӣйҮҚ</text><input class="acc-input" type="digit" value="{{acceptanceItems[item.item_id].gross_weight || ''}}" data-id="{{item.item_id}}" data-field="gross_weight" bindinput="editAcceptanceField" placeholder="0"/></view>
              <view class="acc-field"><text class="acc-label">зҡ®йҮҚ</text><input class="acc-input" type="digit" value="{{acceptanceItems[item.item_id].tare_weight || ''}}" data-id="{{item.item_id}}" data-field="tare_weight" bindinput="editAcceptanceField" placeholder="0"/></view>
              <view class="acc-field"><text class="acc-label">еҮҖйҮҚ</text><input class="acc-input hl" type="digit" value="{{acceptanceItems[item.item_id].net_weight || ''}}" data-id="{{item.item_id}}" data-field="net_weight" bindinput="editAcceptanceField" placeholder="0"/></view>
            </view>
            <!-- еҲ°иҙ§е·®ејӮ -->
            <view class="acc-row">
              <view class="acc-field"><text class="acc-label">еҲ°иҙ§</text><input class="acc-input hl" type="digit" value="{{acceptanceItems[item.item_id].arrival_qty || ''}}" data-id="{{item.item_id}}" data-field="arrival_qty" bindinput="editAcceptanceField" placeholder="0"/></view>
              <view class="acc-field"><text class="acc-label">еҗҲж је…Ҙеә“</text><input class="acc-input hl ok" type="digit" value="{{acceptanceItems[item.item_id].accepted_qty || ''}}" data-id="{{item.item_id}}" data-field="accepted_qty" bindinput="editAcceptanceField" placeholder="0"/></view>
              <view class="acc-field"><text class="acc-label">зјәж–Ө</text><input class="acc-input" type="digit" value="{{acceptanceItems[item.item_id].shortage_qty || ''}}" data-id="{{item.item_id}}" data-field="shortage_qty" bindinput="editAcceptanceField" placeholder="0"/></view>
            </view>
            <view class="acc-row">
              <view class="acc-field"><text class="acc-label">з ҙжҚҹ</text><input class="acc-input" type="digit" value="{{acceptanceItems[item.item_id].damaged_qty || ''}}" data-id="{{item.item_id}}" data-field="damaged_qty" bindinput="editAcceptanceField" placeholder="0"/></view>
              <view class="acc-field"><text class="acc-label">жӢ’ж”¶</text><input class="acc-input" type="digit" value="{{acceptanceItems[item.item_id].rejected_qty || ''}}" data-id="{{item.item_id}}" data-field="rejected_qty" bindinput="editAcceptanceField" placeholder="0"/></view>
              <view class="acc-field"><text class="acc-label">йҖҖиҙ§</text><input class="acc-input" type="digit" value="{{acceptanceItems[item.item_id].returned_qty || ''}}" data-id="{{item.item_id}}" data-field="returned_qty" bindinput="editAcceptanceField" placeholder="0"/></view>
            </view>
            <!-- еҚ•д»·дёҺиҙЁйҮҸ -->
            <view class="acc-row">
              <view class="acc-field"><text class="acc-label">е®һйҷ…еҚ•д»·</text><input class="acc-input" type="digit" value="{{acceptanceItems[item.item_id].actual_unit_cost || ''}}" data-id="{{item.item_id}}" data-field="actual_unit_cost" bindinput="editAcceptanceField" placeholder="0"/></view>
              <view class="acc-toggle" data-id="{{item.item_id}}" bindtap="toggleQuality">
                <text>иҙЁйҮҸеҗҲж ј</text>
                <view class="toggle {{acceptanceItems[item.item_id].quality_ok !== false ? 'on' : 'off'}}"><view class="toggle-knob"></view></view>
              </view>
            </view>
            <view class="acc-row"><input class="acc-input full" value="{{acceptanceItems[item.item_id].acceptance_notes || ''}}" data-id="{{item.item_id}}" data-field="acceptance_notes" bindinput="editAcceptanceStr" placeholder="йӘҢж”¶еӨҮжіЁпјҲйҖүеЎ«пјү" /></view>
          </view>
        </block>
      </view>
    </view>

    <!-- йӘҢж”¶жҢүй’® -->
    <view wx:if="{{acceptanceMode}}" class="acceptance-bar">
      <button class="btn-secondary" bindtap="exitAcceptance">еҸ–ж¶Ҳ</button>
      <button class="btn-primary" bindtap="submitAcceptance" loading="{{submitting}}">йӘҢж”¶зЎ®и®Өе№¶е…Ҙеә“</button>
    </view>
  </block>

  <!-- Bottom bar (йқһйӘҢж”¶жЁЎејҸ) -->
  <view wx:if="{{listData && !confirmed && !acceptanceMode && listData.items.length > 0}}" class="bottom-bar safe-bottom">
    <view class="bottom-summary">
      <text class="bottom-label">е…ұ {{listData.item_count}} йЎ№ В· жҖ»йўқ</text>
      <text class="bottom-amount">ВҘ{{fmt.fixed(listData.total_actual_cost, 2)}}</text>
    </view>
    <button class="btn-secondary" wx:if="{{listData.purchased_count > 0}}" bindtap="openPayment">д»ҳдҫӣеә”е•Ҷж¬ҫ</button>
    <button class="btn-primary bottom-btn" bindtap="confirmPurchase" loading="{{submitting}}">{{listData.status === 'accepted' ? 'зЎ®и®Өе…Ҙеә“' : 'зЎ®и®ӨйҮҮиҙӯе…Ҙеә“'}}</button>
  </view>

  <!-- Confirm result -->
  <view wx:if="{{confirmed && confirmResult}}" class="result-mask" bindtap="goHome">
    <view class="result-card safe-bottom" catchtap="">
      <mascot size="lg" mood="cheer" class="result-mascot"></mascot>
      <text class="result-title">е…Ҙеә“е®ҢжҲҗ</text>
      <text class="result-subtitle">е·Іе…Ҙеә“ {{confirmResult.confirmed_count}} йЎ№</text>
      <view class="result-summary">
        <view class="result-stat"><text class="result-stat-num">{{confirmResult.confirmed_count}}</text><text class="result-stat-label">е·Іе…Ҙеә“</text></view>
        <view class="result-stat-divider"></view>
        <view class="result-stat"><text class="result-stat-num">ВҘ{{fmt.fixed(confirmResult.total_actual_cost, 2)}}</text><text class="result-stat-label">жҖ»жҲҗжң¬</text></view>
      </view>
      <view class="result-list" wx:if="{{confirmResult.records.length > 0}}">
        <view wx:for="{{confirmResult.records}}" wx:key="item_id" class="result-item"><text class="result-item-name">{{item.product_name}}</text><text class="result-item-qty">{{fmt.fixed(item.qty, 1)}}</text></view>
      </view>
      <view class="result-actions">
        <button class="btn-secondary" bindtap="goHome">иҝ”еӣһйҰ–йЎө</button>
        <button class="btn-secondary" bindtap="openPayment">д»ҳдҫӣеә”е•Ҷж¬ҫ</button>
        <button class="btn-primary" bindtap="viewInventory">жҹҘзңӢеә“еӯҳ</button>
      </view>
    </view>
  </view>

  <!-- дҫӣеә”е•ҶйҖүжӢ©еј№зӘ— -->
  <view wx:if="{{showSupplierPicker}}" class="picker-mask" bindtap="closeSupplierPicker">
    <view class="picker-sheet" catchtap="">
      <text class="picker-title">йҖүжӢ©дҫӣеә”е•Ҷ</text>
      <view wx:if="{{suppliers.length}}" class="picker-list">
        <view wx:for="{{suppliers}}" wx:key="supplier_id" class="picker-item" data-id="{{item.supplier_id}}" data-name="{{item.supplier_name}}" bindtap="selectSupplier">
          <text class="picker-name">{{item.supplier_name}}</text>
          <text class="picker-balance {{item.balance > 0 ? 'warn' : ''}}">{{item.balance > 0 ? 'ж¬  ВҘ' + fmt.fixed(item.balance, 0) : 'е·Із»“жё…'}}</text>
        </view>
      </view>
      <view wx:else class="picker-empty">жҡӮж— дҫӣеә”е•ҶжЎЈжЎҲпјҢиҜ·е…ҲеңЁ"жҲ‘зҡ„"вҶ’дҫӣеә”е•Ҷз®ЎзҗҶдёӯж·»еҠ </view>
      <button class="picker-close" bindtap="closeSupplierPicker">е…ій—ӯ</button>
    </view>
  </view>

  <!-- дҫӣеә”е•Ҷд»ҳж¬ҫеј№зӘ— -->
  <view wx:if="{{showPayment}}" class="picker-mask" bindtap="closePayment">
    <view class="picker-sheet" catchtap="">
      <text class="picker-title">д»ҳдҫӣеә”е•Ҷж¬ҫ</text>
      <view class="picker-list">
        <view wx:for="{{suppliers}}" wx:key="supplier_id" class="picker-item {{paymentSupplierId === item.supplier_id ? 'active' : ''}}" data-id="{{item.supplier_id}}" data-name="{{item.supplier_name}}" bindtap="pickPaymentSupplier">
          <text class="picker-name">{{item.supplier_name}}</text>
          <text class="picker-balance {{item.balance > 0 ? 'warn' : ''}}">{{item.balance > 0 ? 'ж¬  ВҘ' + fmt.fixed(item.balance, 0) : 'е·Із»“жё…'}}</text>
        </view>
      </view>
      <view wx:if="{{paymentSupplierId}}" class="payment-form">
        <view class="pay-field"><text class="pay-label">йҮ‘йўқ</text><input class="pay-input" type="digit" value="{{paymentAmount}}" bindinput="editPaymentAmount" placeholder="0.00"/></view>
        <view class="pay-methods">
          <view wx:for="{{[{key:'cash', label:'зҺ°йҮ‘'}, {key:'wechat', label:'еҫ®дҝЎ'}, {key:'bank_transfer', label:'иҪ¬иҙҰ'}]}}" wx:key="key" class="pay-chip {{paymentMethod === item.key ? 'active' : ''}}" data-method="{{item.key}}" bindtap="selectPaymentMethod">{{item.label}}</view>
        </view>
        <input class="pay-input note" value="{{paymentNote}}" bindinput="editPaymentNote" placeholder="еӨҮжіЁпјҲйҖүеЎ«пјү"/>
      </view>
      <view class="picker-actions">
        <button class="btn-secondary" bindtap="closePayment">еҸ–ж¶Ҳ</button>
        <button class="btn-primary" bindtap="submitPayment" loading="{{paymentSubmitting}}" disabled="{{!paymentSupplierId}}">зЎ®и®Өд»ҳж¬ҫ ВҘ{{paymentAmount}}</button>
      </view>
    </view>
  </view>

  <!-- еҜ№иҙҰеҚ•еј№зӘ— -->
  <view wx:if="{{showStatement && statementData}}" class="picker-mask" bindtap="closeStatement">
    <view class="picker-sheet statement-sheet" catchtap="">
      <text class="picker-title">дҫӣеә”е•ҶеҜ№иҙҰеҚ•</text>
      <text class="statement-supplier">{{statementData.supplier_name || 'дҫӣеә”е•Ҷ'}}</text>
      <view class="statement-summary">
        <view class="stmt-stat"><text class="stmt-num">ВҘ{{fmt.fixed(statementData.total_purchases, 0)}}</text><text class="stmt-label">йҮҮиҙӯжҖ»йўқ</text></view>
        <view class="stmt-stat"><text class="stmt-num">ВҘ{{fmt.fixed(statementData.total_payments, 0)}}</text><text class="stmt-label">е·Ід»ҳж¬ҫ</text></view>
        <view class="stmt-stat"><text class="stmt-num {{statementData.current_balance > 0 ? 'warn' : ''}}">ВҘ{{fmt.fixed(statementData.current_balance, 0)}}</text><text class="stmt-label">еҪ“еүҚж¬ ж¬ҫ</text></view>
      </view>
      <view class="statement-list" wx:if="{{statementData.items.length}}">
        <view wx:for="{{statementData.items}}" wx:key="id" class="stmt-item">
          <view class="stmt-left"><text class="stmt-dir">{{item.direction === 'purchase' ? 'йҮҮиҙӯ' : item.direction === 'payment' ? 'д»ҳж¬ҫ' : 'йҖҖиҙ§'}}</text><text class="stmt-note">{{item.note || ''}}</text></view>
          <text class="stmt-amount {{item.direction === 'payment' ? 'ok' : ''}}">{{item.direction === 'payment' ? '-' : '+'}}ВҘ{{fmt.fixed(item.amount, 2)}}</text>
        </view>
      </view>
      <button class="picker-close" bindtap="closeStatement">е…ій—ӯ</button>
    </view>
  </view>

  <!-- йҖҖиҙ§еј№зӘ— -->
  <view wx:if="{{showReturn}}" class="picker-mask" bindtap="closeReturn">
    <view class="picker-sheet" catchtap="">
      <text class="picker-title">йҖҖиҙ§з»ҷдҫӣеә”е•Ҷ</text>
      <view class="payment-form">
        <view class="pay-field"><text class="pay-label">ж•°йҮҸ</text><input class="pay-input" type="digit" value="{{returnQty}}" bindinput="editReturnQty" placeholder="0"/></view>
        <view class="pay-field"><text class="pay-label">еҺҹеӣ </text><input class="pay-input note" value="{{returnReason}}" bindinput="editReturnReason" placeholder="йҖҖиҙ§еҺҹеӣ пјҲеҝ…еЎ«пјү"/></view>
      </view>
      <view class="picker-actions">
        <button class="btn-secondary" bindtap="closeReturn">еҸ–ж¶Ҳ</button>
        <button class="btn-primary" bindtap="submitReturn" loading="{{returnSubmitting}}">зЎ®и®ӨйҖҖиҙ§</button>
      </view>
    </view>
  </view>

</view>
