/* 采购 — 验收 · 付款 · 退货 */
.purchase-page { padding-bottom: 220rpx; }
.purchase-hero { background: var(--green-950); }

/* 状态条 */
.status-bar { display:flex; align-items:center; gap:20rpx; margin-top:22rpx; padding:24rpx 28rpx; background:var(--paper); border:1rpx solid rgba(18,61,48,.06); border-radius:var(--radius-lg); box-shadow:var(--shadow); animation:card-rise .32s ease both; }
.status-block { flex:1; }
.status-block .tag { margin-top:8rpx; }
.status-divider { width:1rpx; height:64rpx; background:var(--line); }
.status-label { display:block; color:var(--muted); font-size:21rpx; }
.status-amount { display:block; margin-top:6rpx; color:var(--green-800); font-size:36rpx; font-weight:850; }
.status-amount-sm { display:block; margin-top:6rpx; font-size:28rpx; font-weight:750; }
.status-amount-sm.ok { color:var(--green-700); }
.status-amount-sm.warn { color:var(--corn); }
.section-action { margin-left:auto; padding:8rpx 18rpx; color:var(--green-800); background:var(--green-50); border:2rpx solid var(--green-200); border-radius:99rpx; font-size:21rpx; font-weight:700; }
.section-action:active { opacity:.7; }

/* 采购卡片 */
.purchase-list { display:flex; flex-direction:column; gap:16rpx; }
.purchase-card { padding:24rpx; background:var(--paper); border:1rpx solid transparent; border-radius:var(--radius-lg); box-shadow:0 8rpx 24rpx rgba(25,48,38,.06); animation:card-rise .32s ease both; }
.purchase-card.purchased { border-color:rgba(31,114,85,.14); background:var(--green-50); }
.purchase-card.returned { border-color:rgba(201,67,51,.14); background:rgba(201,67,51,.04); }
.purchase-card.cancelled { opacity:.5; }

.card-head { display:flex; align-items:center; justify-content:space-between; gap:16rpx; }
.card-title-wrap { display:flex; align-items:center; gap:12rpx; min-width:0; flex:1; flex-wrap:wrap; }
.card-name { max-width:320rpx; overflow:hidden; color:var(--ink); font-size:30rpx; font-weight:720; text-overflow:ellipsis; white-space:nowrap; }
.card-actions { display:flex; align-items:center; gap:14rpx; flex:0 0 auto; }
.action-link { padding:6rpx 14rpx; color:var(--green-800); font-size:20rpx; background:var(--green-50); border-radius:99rpx; }
.action-link.return { color:#c0493d; background:rgba(201,67,51,.08); }
.action-link:active { opacity:.7; }
.cancel-btn { flex:0 0 auto; padding:8rpx 18rpx; color:var(--red); font-size:21rpx; background:var(--red-soft); border-radius:99rpx; }
.cancel-btn:active { opacity:.7; }
.supplier-badge { padding:4rpx 12rpx; color:#9a5c06; background:var(--amber-soft); border-radius:99rpx; font-size:19rpx; font-weight:700; }

/* 验收摘要 */
.acceptance-summary { display:flex; align-items:center; gap:12rpx; margin-top:14rpx; padding:12rpx 16rpx; background:#f0f7f3; border-radius:12rpx; font-size:20rpx; color:var(--muted); flex-wrap:wrap; }
.acc-sum-label { color:var(--green-800); font-weight:700; }
.acceptance-summary .warn { color:#c0493d; }

/* 数量行 */
.qty-row { display:flex; align-items:center; gap:16rpx; margin-top:22rpx; }
.qty-field { display:flex; align-items:baseline; gap:8rpx; min-width:0; }
.qty-label { color:var(--muted); font-size:20rpx; }
.qty-rec { color:var(--ink-2); font-size:28rpx; font-weight:700; }
.qty-actual { color:var(--green-800); font-size:36rpx; font-weight:820; }
.qty-unit { color:var(--muted); font-size:20rpx; }
.qty-sep { color:var(--muted); font-size:24rpx; }
.qty-display { display:flex; align-items:baseline; gap:6rpx; padding:8rpx 18rpx; background:var(--green-50); border-radius:var(--radius-md); }
.qty-display:active { opacity:.8; }
.qty-input { width:110rpx; height:64rpx; color:var(--green-800); font-size:32rpx; font-weight:800; text-align:center; background:var(--paper); border:2rpx solid var(--green-700); border-radius:var(--radius-md); }

.deviation { margin-left:auto; padding:6rpx 14rpx; border-radius:99rpx; font-size:20rpx; font-weight:700; }
.deviation.up { color:var(--green-700); background:var(--green-100); }
.deviation.down { color:var(--red); background:var(--red-soft); }

/* 成本行 */
.cost-row { display:flex; align-items:center; gap:24rpx; margin-top:18rpx; padding:16rpx 20rpx; background:#f8f7f1; border-radius:var(--radius-md); }
.cost-field { display:flex; align-items:baseline; gap:10rpx; }
.cost-label { color:var(--muted); font-size:20rpx; }
.cost-input { width:130rpx; height:60rpx; color:var(--ink); font-size:26rpx; font-weight:700; text-align:center; background:var(--paper); border:1rpx solid var(--line); border-radius:12rpx; }
.cost-subtotal { color:var(--green-800); font-size:28rpx; font-weight:800; }

/* 验收字段 */
.acc-row { display:flex; gap:12rpx; margin-top:12rpx; align-items:center; }
.acc-field { display:flex; flex-direction:column; gap:6rpx; min-width:0; flex:1; }
.acc-field.sm { flex:0 0 90rpx; }
.acc-label { color:var(--muted); font-size:18rpx; }
.acc-input { height:52rpx; padding:0 10rpx; color:var(--ink); font-size:22rpx; font-weight:700; text-align:center; background:var(--paper); border:1rpx solid var(--line); border-radius:10rpx; }
.acc-input.sm { font-size:20rpx; }
.acc-input.hl { border-color:var(--green-300); background:var(--green-50); }
.acc-input.hl.ok { border-color:var(--green-500); }
.acc-input.full { flex:1; text-align:left; font-weight:400; }
.acc-toggle { display:flex; align-items:center; gap:10rpx; margin-top:6rpx; font-size:21rpx; color:var(--ink); font-weight:600; }

/* Toggle */
.toggle { width:80rpx; height:44rpx; border-radius:22rpx; display:flex; align-items:center; padding:3rpx; transition:background .2s; }
.toggle.on { background:var(--green-600); justify-content:flex-end; }
.toggle.off { background:#c4c4c4; justify-content:flex-start; }
.toggle-knob { width:38rpx; height:38rpx; border-radius:50%; background:#fff; box-shadow:0 2rpx 4rpx rgba(0,0,0,.12); }

/* 验收按钮栏 */
.acceptance-bar { display:flex; gap:16rpx; margin-top:28rpx; }
.acceptance-bar .btn-secondary,
.acceptance-bar .btn-primary { flex:1; }

/* AI建议 */
.reason { display:flex; gap:10rpx; margin-top:16rpx; padding-top:16rpx; border-top:1rpx dashed var(--line); }
.reason-tag { flex:0 0 auto; padding:2rpx 10rpx; color:#9a5c06; font-size:18rpx; font-weight:700; background:var(--amber-soft); border-radius:8rpx; }
.reason-text { color:var(--muted); font-size:21rpx; line-height:1.5; }

/* 底部栏 */
.bottom-bar { position:fixed; bottom:0; left:0; right:0; display:flex; align-items:center; gap:20rpx; padding:18rpx 24rpx; background:var(--paper); border-top:1rpx solid var(--line); box-shadow:0 -8rpx 24rpx rgba(25,48,38,.08); z-index:10; }
.bottom-summary { flex:1; display:flex; flex-direction:column; }
.bottom-label { color:var(--muted); font-size:20rpx; }
.bottom-amount { color:var(--green-800); font-size:38rpx; font-weight:850; }
.bottom-btn { flex:0 0 auto; min-width:260rpx; }

/* 弹窗通用 */
.picker-mask { position:fixed; inset:0; z-index:100; display:flex; align-items:flex-end; justify-content:center; background:rgba(0,0,0,.4); }
.picker-sheet { width:100%; max-width:640rpx; max-height:1200rpx; overflow-y:auto; padding:36rpx 28rpx 52rpx; background:var(--paper); border-radius:32rpx 32rpx 0 0; }
.picker-title { display:block; color:var(--ink); font-size:30rpx; font-weight:800; margin-bottom:20rpx; }
.picker-list { margin-bottom:10rpx; }
.picker-item { display:flex; justify-content:space-between; align-items:center; padding:20rpx 16rpx; border-bottom:1rpx solid var(--line); }
.picker-item.active { background:var(--green-50); border-radius:14rpx; }
.picker-item:active { opacity:.7; }
.picker-name { color:var(--ink); font-size:26rpx; font-weight:700; }
.picker-balance { font-size:22rpx; color:var(--muted); }
.picker-balance.warn { color:#c0493d; font-weight:700; }
.picker-empty { padding:32rpx; text-align:center; color:var(--muted); font-size:22rpx; }
.picker-close { margin-top:20rpx; color:var(--muted); background:var(--paper); border:2rpx solid var(--line); border-radius:20rpx; font-size:24rpx; }
.picker-actions { display:flex; gap:14rpx; margin-top:24rpx; }
.picker-actions .btn-secondary,
.picker-actions .btn-primary { flex:1; }

/* 付款表单 */
.payment-form { margin-top:16rpx; }
.pay-field { display:flex; align-items:center; gap:14rpx; margin-bottom:14rpx; }
.pay-label { color:var(--muted); font-size:24rpx; flex:0 0 auto; }
.pay-input { flex:1; height:64rpx; padding:0 16rpx; color:var(--ink); font-size:30rpx; font-weight:800; background:var(--green-50); border:2rpx solid var(--green-200); border-radius:16rpx; }
.pay-input.note { font-size:24rpx; font-weight:400; }
.pay-methods { display:flex; gap:10rpx; margin-bottom:14rpx; }
.pay-chip { padding:14rpx 20rpx; color:var(--muted); background:var(--paper); border:2rpx solid var(--line); border-radius:14rpx; font-size:22rpx; font-weight:700; }
.pay-chip.active { color:#fff; background:var(--green-700); border-color:var(--green-700); }
.pay-chip:active { opacity:.7; }

/* 对账单 */
.statement-sheet { max-height:1000rpx; }
.statement-supplier { display:block; color:var(--green-800); font-size:26rpx; font-weight:700; margin-bottom:16rpx; }
.statement-summary { display:flex; gap:16rpx; margin-bottom:20rpx; padding:20rpx; background:var(--green-50); border-radius:16rpx; }
.stmt-stat { flex:1; text-align:center; }
.stmt-num { display:block; color:var(--ink); font-size:30rpx; font-weight:850; }
.stmt-num.warn { color:#c0493d; }
.stmt-label { display:block; margin-top:4rpx; color:var(--muted); font-size:19rpx; }
.statement-list { max-height:420rpx; overflow-y:auto; }
.stmt-item { display:flex; justify-content:space-between; align-items:flex-start; padding:16rpx 0; border-bottom:1rpx solid var(--line); }
.stmt-left { flex:1; min-width:0; }
.stmt-dir { display:block; color:var(--ink); font-size:24rpx; font-weight:700; }
.stmt-note { display:block; margin-top:4rpx; color:var(--muted); font-size:19rpx; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.stmt-amount { color:var(--ink); font-family:var(--font-num); font-size:24rpx; font-weight:800; flex:0 0 auto; }
.stmt-amount.ok { color:var(--green-700); }

/* 空状态 */
.empty-purchase { padding:72rpx 30rpx; }
.empty-title { display:block; margin-top:14rpx; color:var(--ink); font-size:28rpx; font-weight:720; }
.empty-desc { display:block; margin-top:8rpx; color:var(--muted); font-size:22rpx; line-height:1.5; }
.empty-action { margin:28rpx auto 0; width:320rpx; }

/* 结果弹窗 */
.result-mask { position:fixed; top:0; left:0; right:0; bottom:0; display:flex; align-items:center; justify-content:center; padding:40rpx; background:rgba(18,34,29,.55); z-index:100; animation:fade-in .2s ease both; }
.result-card { width:100%; max-width:620rpx; max-height:1050rpx; overflow-y:auto; padding:40rpx 32rpx 32rpx; background:var(--paper); border-radius:var(--radius-xl); box-shadow:0 20rpx 60rpx rgba(0,0,0,.2); animation:card-rise .3s ease both; }
.result-mascot { width:140rpx; height:140rpx; margin:0 auto 20rpx; display:block; }
.result-title { display:block; text-align:center; color:var(--ink); font-size:32rpx; font-weight:760; }
.result-subtitle { display:block; margin-top:6rpx; text-align:center; color:var(--muted); font-size:22rpx; }
.result-summary { display:flex; align-items:center; justify-content:center; gap:30rpx; margin:28rpx 0; padding:24rpx; background:var(--green-50); border-radius:var(--radius-lg); }
.result-stat { text-align:center; }
.result-stat-num { display:block; color:var(--green-800); font-size:38rpx; font-weight:850; }
.result-stat-label { display:block; margin-top:4rpx; color:var(--muted); font-size:20rpx; }
.result-stat-divider { width:1rpx; height:56rpx; background:var(--line); }
.result-list { max-height:360rpx; overflow-y:auto; margin:8rpx 0 20rpx; padding:0 8rpx; }
.result-item { display:flex; align-items:center; justify-content:space-between; gap:16rpx; padding:16rpx 0; border-bottom:1rpx solid var(--line); }
.result-item-name { color:var(--ink); font-size:24rpx; font-weight:600; }
.result-item-qty { color:var(--green-800); font-size:24rpx; font-weight:700; }
.result-actions { display:flex; gap:16rpx; margin-top:8rpx; flex-wrap:wrap; }
.result-actions .btn-secondary,
.result-actions .btn-primary { flex:1; min-width:200rpx; }

/* 骨架屏 */
.purchase-skeleton { padding-top:20rpx; }
.skel-bar { display:flex; align-items:center; gap:16rpx; padding:24rpx 28rpx; background:var(--paper); border-radius:var(--radius-lg); margin-bottom:18rpx; }
.skel-card { margin-bottom:16rpx; padding:28rpx; background:var(--paper); border-radius:var(--radius-lg); }
.skel-line { background:linear-gradient(90deg, #ebece6 25%, #f5f5f0 50%, #ebece6 75%); background-size:300% 100%; animation:shimmer 1.35s infinite; border-radius:99rpx; height:24rpx; }
.skel-line.title { width:48%; height:30rpx; }
.skel-line.medium { width:200rpx; }
.skel-line.short { width:130rpx; }
.skel-line:not(:first-child) { margin-top:18rpx; }

.tag-muted { color:var(--muted); background:#f0efe8; }
.tag-blue { color:#1a6fb5; background:#e6f2fa; }
.tag-red { color:#c0493d; background:rgba(201,67,51,.08); }
.tag-amber { color:#9a5c06; background:var(--amber-soft); }
.tag-green { color:#1f7255; background:rgba(31,114,85,.1); }

@keyframes shimmer { 0% { background-position:100% 0; } 100% { background-position:-100% 0; } }
@keyframes card-rise { from { opacity:0; transform:translateY(12rpx); } to { opacity:1; transform:translateY(0); } }
@keyframes fade-in { from { opacity:0; } to { opacity:1; } }
