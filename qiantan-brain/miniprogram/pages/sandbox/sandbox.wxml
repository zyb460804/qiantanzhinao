<!-- 决策沙盘 · 把复杂参数变成一步一步的经营试算 -->
<wxs src="/utils/format.wxs" module="fmt" />
<view class="page-shell sandbox-page {{skinClass}}">
  <view class="page-hero sandbox-hero page-hero--breathing">
    <text class="eyebrow">WHAT-IF LAB · 决策试算</text>
    <text class="hero-title">进货之前，先预演结果</text>
    <text class="hero-desc">调整进货量、成本与售价，对比销量、净利润和损耗。</text>
    <view class="lab-steps"><text class="active">1 设置参数</text><text>2 运行模拟</text><text>3 对比方案</text></view>
  </view>

  <view class="section-head"><text class="section-title">设置这次试算</text><text class="tag tag-green">约10秒</text></view>
  <view class="config-panel">
    <view class="field-row">
      <view class="field-copy"><text class="field-label">选择商品</text><text class="field-help">使用当前库存商品</text></view>
      <picker mode="selector" range="{{products}}" value="{{productIndex}}" bindchange="onProductChange"><view class="picker-value">{{products[productIndex] || '请选择'}}<text>⌄</text></view></picker>
    </view>
    <view class="field-block">
      <view class="slider-head"><view><text class="field-label">计划进货量</text><text class="field-help">拖动滑块快速调整</text></view><text class="quantity-value">{{purchaseQty}}<text> 斤</text></text></view>
      <slider min="1" max="300" value="{{purchaseQty}}" bindchange="onSliderChange" block-size="22" block-color="#175C45" activeColor="#175C45" backgroundColor="#E4E7E1"/>
      <view class="range-label"><text>1斤</text><text>300斤</text></view>
    </view>
    <view class="price-grid">
      <view class="price-field"><text class="field-label">进货单价</text><view class="money-input"><text>¥</text><input type="digit" value="{{unitCost}}" data-field="unitCost" bindinput="onFieldInput" placeholder="0.5"/><text class="unit">/斤</text></view></view>
      <view class="price-field"><text class="field-label">计划售价</text><view class="money-input"><text>¥</text><input type="digit" value="{{unitPrice}}" data-field="unitPrice" bindinput="onFieldInput" placeholder="2.0"/><text class="unit">/斤</text></view></view>
    </view>
    <button class="run-button" bindtap="runSimulation" loading="{{loading}}" disabled="{{loading || productsEmpty}}"><text class="run-mark">算</text>{{loading ? '正在推演...' : '开始经营试算'}}</button>
  </view>

  <view wx:if="{{result && result.single}}">
    <view class="section-head"><text class="section-title">本次结果</text><text class="tag {{result.single.comparison.improvement >= 0 ? 'tag-green' : 'tag-red'}}">{{result.single.comparison.verdict}}</text></view>
    <view class="profit-card">
      <text class="profit-label">预计净利润</text>
      <text class="profit-number {{result.single.output.net_profit >= 0 ? 'green' : 'red'}}">¥{{result.single.output.net_profit}}</text>
      <view class="profit-grid">
        <view><text>{{result.single.output.estimated_sales}}</text><text>预计销量/斤</text></view>
        <view><text>¥{{result.single.output.estimated_revenue}}</text><text>预计收入</text></view>
        <view><text>{{fmt.percent(result.single.output.waste_rate)}}%</text><text>预计损耗</text></view>
      </view>
      <view class="cost-lines"><view><text>进货成本</text><text>-¥{{result.single.output.total_cost}}</text></view><view><text>损耗损失</text><text>-¥{{result.single.output.waste_loss}}</text></view></view>
      <view class="recommendation"><text class="rec-mark">策</text><text>{{result.single.comparison.recommendation}}</text></view>
    </view>
  </view>

  <view wx:if="{{result && result.multi}}">
    <view class="section-head"><text class="section-title">三种方案对比</text><text class="section-caption">找到利润与风险平衡点</text></view>
    <view class="compare-card">
      <canvas type="2d" id="sandboxCanvas" class="chart-canvas"></canvas>
      <view class="compare-table">
        <view class="table-row table-head"><text>方案</text><text>进货量</text><text>净收益</text><text>损耗率</text></view>
        <view wx:for="{{result.multi}}" wx:key="name" class="table-row"><text class="scheme-name">{{item.name}}</text><text>{{item.purchase_qty}}斤</text><text class="{{item.net_profit >= 0 ? 'green' : 'red'}}">¥{{item.net_profit}}</text><text>{{fmt.percent(item.waste_rate)}}%</text></view>
      </view>
    </view>
  </view>
</view>
