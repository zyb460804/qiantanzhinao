.sandbox-page { padding-top: 22rpx; }
.sandbox-hero { background: var(--green-950); }
.lab-steps { position: relative; z-index: 2; display: flex; gap: 20rpx; margin-top: 30rpx; padding-top: 20rpx; border-top: 1rpx solid rgba(255,255,255,.13); color: rgba(255,255,255,.45); font-size: 20rpx; }
.lab-steps .active { color: #f6ca78; font-weight: 700; }
.config-panel { padding: 28rpx; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.field-row { display: flex; align-items: center; justify-content: space-between; padding-bottom: 26rpx; border-bottom: 1rpx solid var(--line); }
.field-label, .field-help { display: block; }
.field-label { color: var(--ink); font-size: 26rpx; font-weight: 700; }
.field-help { margin-top: 3rpx; color: var(--muted); font-size: 20rpx; }
.picker-value { display: flex; align-items: center; gap: 14rpx; min-width: 210rpx; padding: 16rpx 18rpx; color: var(--green-800); background: var(--green-50); border-radius: 15rpx; font-size: 25rpx; font-weight: 700; }
.picker-value > text { margin-left: auto; }
.field-block { padding: 28rpx 0; border-bottom: 1rpx solid var(--line); }
.slider-head { display: flex; align-items: flex-end; justify-content: space-between; }
.quantity-value { color: var(--green-800); font-size: 42rpx; font-weight: 800; }
.quantity-value > text { font-size: 22rpx; font-weight: 500; }
.field-block slider { margin: 22rpx 0 0; }
.range-label { display: flex; justify-content: space-between; color: var(--muted); font-size: 18rpx; }
.price-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; padding-top: 26rpx; }
.price-field { min-width: 0; }
.money-input { display: flex; align-items: center; margin-top: 12rpx; padding: 18rpx; background: var(--paper-2); border: 1rpx solid var(--line); border-radius: 16rpx; color: var(--green-800); font-size: 25rpx; font-weight: 700; }
.money-input input { flex: 1; min-width: 0; margin-left: 7rpx; color: var(--ink); font-size: 29rpx; }
.money-input .unit { color: var(--muted); font-size: 18rpx; font-weight: 500; }
.run-button { display: flex; align-items: center; justify-content: center; gap: 14rpx; min-height: 96rpx; margin-top: 28rpx; color: #fff; background: var(--green-800); border-radius: 20rpx; font-size: 29rpx; font-weight: 750; box-shadow: 0 12rpx 26rpx rgba(23,92,69,.22); }
.run-mark { display: flex; align-items: center; justify-content: center; width: 40rpx; height: 40rpx; color: var(--green-950); background: #f6ca78; border-radius: 12rpx; font-size: 20rpx; font-weight: 800; }
.profit-card { padding: 30rpx; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.profit-label { display: block; color: var(--muted); font-size: 22rpx; }
.profit-number { display: block; margin-top: 3rpx; font-size: 60rpx; line-height: 1.25; font-weight: 820; letter-spacing: -2rpx; }
.profit-grid { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 24rpx; padding: 22rpx 0; background: var(--paper-2); border-radius: 18rpx; }
.profit-grid > view { padding: 0 14rpx; text-align: center; border-right: 1rpx solid var(--line); }
.profit-grid > view:last-child { border-right: 0; }
.profit-grid text { display: block; }
.profit-grid text:first-child { color: var(--ink); font-size: 27rpx; font-weight: 750; }
.profit-grid text:last-child { margin-top: 4rpx; color: var(--muted); font-size: 18rpx; }
.cost-lines { margin-top: 20rpx; }
.cost-lines > view { display: flex; justify-content: space-between; padding: 10rpx 0; color: var(--ink-2); font-size: 23rpx; }
.recommendation { display: flex; align-items: flex-start; gap: 14rpx; margin-top: 18rpx; padding: 18rpx; color: var(--green-800); background: var(--green-50); border-radius: 16rpx; font-size: 23rpx; }
.rec-mark { flex: 0 0 auto; display: flex; align-items: center; justify-content: center; width: 34rpx; height: 34rpx; color: #fff; background: var(--green-700); border-radius: 10rpx; font-size: 18rpx; font-weight: 800; }
.compare-card { padding: 26rpx; background: var(--paper); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
.chart-canvas { width: 100%; height: 390rpx; }
.compare-table { margin-top: 20rpx; overflow: hidden; border: 1rpx solid var(--line); border-radius: 16rpx; }
.table-row { display: grid; grid-template-columns: 1.15fr 1fr 1fr 1fr; padding: 18rpx 14rpx; border-bottom: 1rpx solid var(--line); color: var(--ink-2); font-size: 21rpx; text-align: right; }
.table-row:last-child { border-bottom: 0; }
.table-row text:first-child { text-align: left; }
.table-head { color: var(--muted); background: var(--paper-2); font-size: 19rpx; font-weight: 650; }
.scheme-name { color: var(--ink); font-weight: 700; }
