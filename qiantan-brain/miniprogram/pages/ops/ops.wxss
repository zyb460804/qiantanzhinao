.ops-page { padding-bottom:100rpx; }
.tab-row { display:flex; gap:12rpx; margin:16rpx 0; overflow-x:auto; }
.tab-chip { padding:14rpx 24rpx; color:var(--muted); background:var(--paper); border:2rpx solid var(--line); border-radius:99rpx; font-size:24rpx; font-weight:700; white-space:nowrap; flex:0 0 auto; }
.tab-chip.active { color:#fff; background:var(--green-700); border-color:var(--green-700); }

.cat-list { overflow:hidden; background:var(--paper); border-radius:24rpx; box-shadow:var(--shadow); margin-bottom:20rpx; }
.cat-item { display:flex; align-items:center; padding:20rpx 24rpx; border-bottom:1rpx solid var(--line); gap:12rpx; }
.cat-item:last-child { border-bottom:none; }
.cat-main { flex:1; min-width:0; }
.cat-name { display:block; color:var(--ink); font-size:27rpx; font-weight:750; }
.cat-meta { display:block; margin-top:4rpx; color:var(--muted); font-size:20rpx; }
.cat-amount { font-family:var(--font-num); font-size:25rpx; font-weight:800; flex:0 0 auto; }
.cat-amount.warn { color:#c0493d; }
.cat-balance { font-size:23rpx; font-weight:700; flex:0 0 auto; }
.cat-balance.warn { color:#c0493d; }
.cat-actions { display:flex; gap:8rpx; flex:0 0 auto; }
.act-btn { padding:6rpx 14rpx; color:var(--green-800); background:var(--green-50); border-radius:99rpx; font-size:20rpx; }
.act-btn:active { opacity:.7; }

/* 报损表单 */
.picker-mask { position:fixed; inset:0; z-index:100; display:flex; align-items:flex-end; justify-content:center; background:rgba(0,0,0,.4); }
.picker-sheet { width:100%; max-width:640rpx; max-height:1200rpx; overflow-y:auto; padding:36rpx 28rpx 52rpx; background:var(--paper); border-radius:32rpx 32rpx 0 0; }
.picker-title { display:block; color:var(--ink); font-size:30rpx; font-weight:800; margin-bottom:20rpx; }
.picker-actions { display:flex; gap:14rpx; margin-top:24rpx; }
.picker-actions .btn-secondary,.picker-actions .btn-primary { flex:1; }
.picker-close { margin-top:20rpx; color:var(--muted); background:var(--paper); border:2rpx solid var(--line); border-radius:20rpx; font-size:24rpx; }
.form-input { width:100%; height:72rpx; margin-bottom:14rpx; padding:0 20rpx; color:var(--ink); font-size:26rpx; background:var(--green-50); border:2rpx solid var(--line); border-radius:16rpx; box-sizing:border-box; }
.form-input.flex-1 { flex:1; width:auto; }
.form-label { display:block; margin-bottom:8rpx; color:var(--muted); font-size:22rpx; }
.prod-pick-list { max-height:260rpx; overflow-y:auto; margin-bottom:10rpx; }
.prod-pick-item { padding:16rpx; border-bottom:1rpx solid var(--line); font-size:24rpx; color:var(--ink); }
.prod-pick-item:active { background:var(--green-50); }

.reason-grid { display:flex; flex-wrap:wrap; gap:10rpx; margin-bottom:14rpx; }
.reason-chip { padding:10rpx 18rpx; color:var(--muted); background:var(--paper); border:2rpx solid var(--line); border-radius:14rpx; font-size:21rpx; }
.reason-chip.active { color:#fff; background:var(--green-700); border-color:var(--green-700); }

/* 临期 */
.hours-row { display:flex; gap:10rpx; margin-bottom:18rpx; }
.hours-chip { padding:12rpx 24rpx; color:var(--muted); background:var(--paper); border:2rpx solid var(--line); border-radius:14rpx; font-size:22rpx; font-weight:700; }
.hours-chip.active { color:#fff; background:var(--green-700); border-color:var(--green-700); }
.clearance-list { display:flex; flex-direction:column; gap:14rpx; }
.clear-card { padding:22rpx; background:var(--paper); border-radius:20rpx; box-shadow:var(--shadow-sm); }
.clear-head { display:flex; justify-content:space-between; align-items:center; }
.clear-name { color:var(--ink); font-size:27rpx; font-weight:750; }
.risk-tag { padding:4rpx 14rpx; border-radius:99rpx; font-size:19rpx; font-weight:700; }
.risk-tag.high { color:#fff; background:#c0493d; }
.risk-tag.medium { color:#9a5c06; background:var(--amber-soft); }
.risk-tag.low { color:var(--green-700); background:var(--green-100); }
.clear-stats { display:flex; gap:20rpx; margin-top:10rpx; color:var(--muted); font-size:22rpx; }
.clear-suggest { display:flex; justify-content:space-between; align-items:center; margin-top:14rpx; padding-top:14rpx; border-top:1rpx dashed var(--line); color:var(--green-800); font-size:23rpx; font-weight:700; }

/* 对账单 */
.statement-sheet { max-height:1000rpx; }
.statement-summary { display:flex; gap:16rpx; margin-bottom:20rpx; padding:20rpx; background:var(--green-50); border-radius:16rpx; }
.stmt-stat { flex:1; text-align:center; }
.stmt-num { display:block; color:var(--ink); font-size:30rpx; font-weight:850; }
.stmt-num.warn { color:#c0493d; }
.stmt-label { display:block; margin-top:4rpx; color:var(--muted); font-size:19rpx; }
.statement-list { max-height:420rpx; overflow-y:auto; }
.stmt-item { display:flex; justify-content:space-between; align-items:flex-start; padding:16rpx 0; border-bottom:1rpx solid var(--line); }
.stmt-left { flex:1; min-width:0; }
.stmt-dir { display:block; color:var(--ink); font-size:24rpx; font-weight:700; }
.stmt-note { display:block; margin-top:4rpx; color:var(--muted); font-size:19rpx; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.stmt-amount { color:var(--ink); font-family:var(--font-num); font-size:24rpx; font-weight:800; flex:0 0 auto; }
.stmt-amount.ok { color:var(--green-700); }

/* 导出 */
.export-card { padding:24rpx; background:var(--paper); border-radius:24rpx; box-shadow:var(--shadow); }
.date-row { display:flex; align-items:center; gap:12rpx; }
.date-sep { color:var(--muted); }
.export-btns { display:grid; grid-template-columns:1fr 1fr; gap:12rpx; margin-top:20rpx; }

.link { color:var(--green-800); font-weight:700; }
.empty-state { padding:38rpx; text-align:center; color:var(--muted); font-size:24rpx; }

/* 2026 统一设计升级：经营事务中心 */
.ops-page { padding: 0 28rpx 90rpx; }
.ops-hero { margin: 0 -28rpx; padding: 34rpx 32rpx 28rpx; border-radius: 0 0 30rpx 30rpx; }
.ops-hero .hero-desc { display: block; margin-top: 10rpx; color: rgba(255,255,255,.68); font-size: 21rpx; }
.ops-pulse { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 24rpx; padding: 16rpx 6rpx; background: rgba(255,255,255,.1); border: 1rpx solid rgba(255,255,255,.14); border-radius: 20rpx; }
.ops-pulse view { text-align: center; border-right: 1rpx solid rgba(255,255,255,.12); }
.ops-pulse view:last-child { border-right: 0; }
.ops-pulse-num { display: block; color: #fff; font-family: var(--font-num); font-size: 31rpx; font-weight: 850; }
.ops-pulse-num.warn { color: var(--corn); }
.ops-pulse-label { display: block; margin-top: 5rpx; color: rgba(255,255,255,.63); font-size: 18rpx; }
.ops-tabs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin: 20rpx 0 24rpx; padding: 5rpx; background: var(--paper-2); border-radius: 18rpx; overflow: visible; }
.ops-tabs .tab-chip { padding: 14rpx 4rpx; text-align: center; background: transparent; border: 0; border-radius: 14rpx; font-size: 21rpx; }
.ops-tabs .tab-chip.active { color: var(--green-800); background: var(--paper); box-shadow: var(--shadow-sm); }
.ops-page .cat-list, .clear-card, .export-card { border: 1.5rpx solid var(--ring); box-shadow: var(--shadow-sm); }
.ops-page .empty-state { margin-top: 12rpx; padding: 56rpx 28rpx; background: var(--paper); border: 2rpx dashed var(--line); border-radius: 22rpx; }
.hours-row { padding: 5rpx; background: var(--paper-2); border-radius: 16rpx; }
.hours-chip { flex: 1; padding: 12rpx 8rpx; text-align: center; background: transparent; border: 0; }
.hours-chip.active { color: var(--green-800); background: var(--paper); box-shadow: var(--shadow-sm); }
